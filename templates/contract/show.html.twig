{% extends 'base.html.twig' %}

{% block title %}Verification de la convention{% endblock %}

{% block content %}
    <style>
        .contract-review-hero {
            background: linear-gradient(135deg, #f6f9ff 0%, #eef4ff 100%);
            border: 1px solid rgba(13, 110, 253, 0.12);
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 18px 45px rgba(15, 76, 129, 0.08);
        }

        .contract-review-section .card-header {
            border-bottom: 1px solid #eef2f7;
            padding: 1rem 1.25rem;
        }

        .contract-review-section .card-body {
            padding: 1.25rem;
        }

        .contract-review-final {
            background: linear-gradient(135deg, #f2fff6 0%, #ebfff2 100%);
            border: 1px solid rgba(25, 135, 84, 0.18);
            border-radius: 1.5rem;
            box-shadow: 0 20px 44px rgba(25, 135, 84, 0.1);
        }

        .contract-review-final .btn {
            border-radius: 999px;
            padding: 0.9rem 1.4rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ff7a18 0%, #ffb347 100%);
            border-color: #ff9a3d;
            color: #1f2937;
            box-shadow: 0 14px 32px rgba(255, 122, 24, 0.28);
        }

        .contract-review-status {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            padding: 0.65rem 1rem;
            border-radius: 999px;
            background: #fff3cd;
            color: #7a5a00;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-size: 0.82rem;
        }

        .contract-review-final .btn:hover,
        .contract-review-final .btn:focus {
            background: linear-gradient(135deg, #ff8f32 0%, #ffc36a 100%);
            border-color: #ff9a3d;
            color: #1f2937;
        }

        .contract-review-table th {
            white-space: nowrap;
        }
    </style>
    <main class="container py-5">
        <div class="contract-review-hero">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-column flex-lg-row">
            <div>
                <h1 class="h2 mb-1">Verification de la convention #{{ contract.id }}</h1>
                <p class="text-muted mb-0">Relisez les informations saisies avant de transmettre la convention au professeur referent.</p>
            </div>
                <div class="d-flex flex-column align-items-lg-end gap-2">
                    <span class="contract-review-status">
                        <i class="fas fa-shield-alt"></i>
                        {% if contract.status == 'filled_by_company' %}
                            Verification requise
                        {% elseif contract.status == 'refused' %}
                            Collecte rejetee
                        {% else %}
                            {{ contract.statusLabel }}
                        {% endif %}
                    </span>
                    <a href="{{ path('app_student_show', {'id': app.user.id}) }}" class="btn btn-outline-secondary">
                        Retour au tableau de bord
                    </a>
                </div>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-3">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if contract.status == 'refused' %}
            <div class="alert alert-danger mb-4">
                <h2 class="h5 mb-2">Collecte rejetee par le professeur referent</h2>
                <p class="mb-0">
                    {% if contract.professorRejectionReason %}
                        {{ contract.professorRejectionReason|nl2br }}
                    {% else %}
                        Votre professeur referent a refuse cette collecte. Verifiez les informations saisies avant de relancer la procedure.
                    {% endif %}
                </p>
            </div>
        {% endif %}

        <div class="row g-4">
            <div class="col-lg-6">
                <section class="card shadow-sm h-100 contract-review-section">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Entreprise</h2>
                    </div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Nom :</strong> {{ contract.organisation.name }}</p>
                        <p class="mb-2"><strong>Adresse siege :</strong> {{ contract.organisation.addressHq }}, {{ contract.organisation.postalCodeHq }} {{ contract.organisation.cityHq }}</p>
                        <p class="mb-2"><strong>Adresse stage :</strong> {{ contract.organisation.addressInternship }}, {{ contract.organisation.postalCodeInternship }} {{ contract.organisation.cityInternship }}</p>
                        <p class="mb-2"><strong>Responsable :</strong> {{ contract.organisation.respName }} - {{ contract.organisation.respFunction }}</p>
                        <p class="mb-2"><strong>Email :</strong> {{ contract.organisation.respEmail }}</p>
                        <p class="mb-0"><strong>Telephone :</strong> {{ contract.organisation.respPhone }}</p>
                    </div>
                </section>
            </div>

            <div class="col-lg-6">
                <section class="card shadow-sm h-100 contract-review-section">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Tuteur et encadrement</h2>
                    </div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Tuteur entreprise :</strong> {{ contract.tutor.firstname }} {{ contract.tutor.lastname }}</p>
                        <p class="mb-2"><strong>Email tuteur :</strong> {{ contract.tutor.email }}</p>
                        <p class="mb-2"><strong>Telephone tuteur :</strong> {{ contract.tutor.telMobile ?: contract.tutor.telOther ?: 'Non renseigne' }}</p>
                        <p class="mb-0"><strong>Professeur referent :</strong> {{ contract.coordinator.firstname }} {{ contract.coordinator.lastname }}</p>
                    </div>
                </section>
            </div>

            <div class="col-12">
                <section class="card shadow-sm contract-review-section">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Activites prevues</h2>
                    </div>
                    <div class="card-body">
                        <div class="bg-light rounded p-3">{{ contract.plannedActivities|nl2br }}</div>
                    </div>
                </section>
            </div>

            <div class="col-12">
                <section class="card shadow-sm contract-review-section">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Conditions et horaires</h2>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p class="mb-2"><strong>Deplacements :</strong> {{ contract.deplacement ? 'Oui' : 'Non' }}</p>
                                <p class="mb-2"><strong>Transport pris en charge :</strong> {{ contract.transportFreeTaken ? 'Oui' : 'Non' }}</p>
                                <p class="mb-2"><strong>Repas pris en charge :</strong> {{ contract.lunchTaken ? 'Oui' : 'Non' }}</p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-2"><strong>Hebergement pris en charge :</strong> {{ contract.hostTaken ? 'Oui' : 'Non' }}</p>
                                <p class="mb-2"><strong>Gratification :</strong> {{ contract.bonus ? 'Oui' : 'Non' }}</p>
                                <p class="mb-2"><strong>Montant gratification :</strong> {{ contract.bonusAmount ? contract.bonusAmount ~ ' EUR' : 'Non renseigne' }}</p>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-bordered align-middle mb-0 contract-review-table">
                                <thead class="table-light">
                                <tr>
                                    <th>Jour</th>
                                    <th>Matin debut</th>
                                    <th>Matin fin</th>
                                    <th>Apres-midi debut</th>
                                    <th>Apres-midi fin</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for day, schedule in contract.workHours %}
                                    <tr>
                                        <td class="fw-semibold text-capitalize">{{ day }}</td>
                                        <td>{{ schedule.m_start ?: '-' }}</td>
                                        <td>{{ schedule.m_end ?: '-' }}</td>
                                        <td>{{ schedule.am_start ?: '-' }}</td>
                                        <td>{{ schedule.am_end ?: '-' }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <div class="card contract-review-final mt-4 border-0">
            <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h2 class="h4 mb-1 text-success">Derniere verification etudiante</h2>
                    <p class="text-muted mb-0">Si toutes les informations sont correctes, transmettez maintenant la convention a votre professeur referent pour validation pedagogique.</p>
                </div>

                {% if contract.status == 'filled_by_company' %}
                    <form method="post" action="{{ path('app_contract_validate_by_student', {'id': contract.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('validate_by_student' ~ contract.id) }}">
                        <button class="btn btn-lg" type="submit">
                            <i class="fas fa-paper-plane me-2"></i> Valider et transmettre au professeur
                        </button>
                    </form>
                {% else %}
                    <span class="badge bg-secondary fs-6 px-3 py-2">{{ contract.statusLabel }}</span>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}
