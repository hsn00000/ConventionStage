{% extends 'emails/layout.html.twig' %}

{% block title %}Validation requise – Convention de stage – Conventio{% endblock %}
{% block icon %}✅{% endblock %}
{% block badge %}Action requise{% endblock %}
{% block heading %}Une convention est prête<br>à être validée{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">
        Bonjour <strong style="color:#1a1a2e;">{{ professor.firstname }} {{ professor.lastname }}</strong>,
    </p>

    <p style="margin:0 0 24px;font-size:15px;color:#495057;line-height:1.7;">
        Le tuteur en entreprise vient de compléter les informations administratives pour la convention de stage de votre étudiant(e).
        La convention est désormais <strong style="color:#0d6efd;">en attente de votre validation</strong>.
    </p>

    {# Récapitulatif #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f0f4ff;border-radius:12px;padding:20px 24px;">
                <p style="margin:0 0 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6ea8fe;">
                    📋 Récapitulatif du stage
                </p>
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td width="50%" style="padding:8px 0;border-bottom:1px solid #dde6ff;">
                            <p style="margin:0 0 3px;font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;">Étudiant(e)</p>
                            <p style="margin:0;font-size:14px;font-weight:700;color:#1a1a2e;">{{ contract.student.firstname }} {{ contract.student.lastname }}</p>
                        </td>
                        <td width="50%" style="padding:8px 0 8px 20px;border-bottom:1px solid #dde6ff;">
                            <p style="margin:0 0 3px;font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;">Entreprise</p>
                            <p style="margin:0;font-size:14px;font-weight:700;color:#1a1a2e;">{{ contract.organisation.name }}</p>
                        </td>
                    </tr>
                    {% if contract.coordinator is defined %}
                    <tr>
                        <td colspan="2" style="padding:8px 0 0;">
                            <p style="margin:0 0 3px;font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;">Professeur référent</p>
                            <p style="margin:0;font-size:14px;font-weight:700;color:#1a1a2e;">{{ contract.coordinator.firstname }} {{ contract.coordinator.lastname }}</p>
                        </td>
                    </tr>
                    {% endif %}
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Connectez-vous à votre tableau de bord pour consulter les détails et valider la convention :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 16px;">
                <a href="{{ url('app_professor_show', {'id': professor.id}) }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:15px 36px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 20px rgba(13,110,253,0.4);">
                    Accéder à mon tableau de bord &rarr;
                </a>
            </td>
        </tr>
        <tr>
            <td style="padding:0 40px 16px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:#fff8e1;border-left:4px solid #ffc107;border-radius:0 8px 8px 0;padding:12px 16px;">
                            <p style="margin:0;font-size:13px;color:#856404;line-height:1.6;">
                                ⚡ Une action de votre part est requise pour finaliser la convention de stage.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
{% endblock %}
