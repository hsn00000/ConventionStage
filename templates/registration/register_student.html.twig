{% extends 'base.html.twig' %}

{% block title %}Inscription Étudiant - Conventio{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <style>
        .ts-wrapper .ts-control {
            border-radius: 0.375rem;
            border-color: #dee2e6;
            padding: 0.5rem 0.75rem;
            font-size: 1rem;
            min-height: calc(1.5em + 1rem + 2px);
        }
        .ts-wrapper.focus .ts-control {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
        .ts-wrapper .ts-dropdown {
            border-color: #dee2e6;
            border-radius: 0.375rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1);
        }
        .ts-wrapper .ts-dropdown .option.selected {
            background-color: #0d6efd;
        }
        .ts-wrapper .ts-dropdown .option:hover {
            background-color: #e8f0fe;
            color: #0d6efd;
        }
    </style>
{% endblock %}

{% block back_button %}
    <div class="container pt-3">
        <button onclick="history.back()" class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;padding:0;">
            <i class="ph ph-arrow-left" style="font-size:1.1rem;"></i>
        </button>
    </div>
{% endblock %}

{% block body %}
    <main class="container-fluid d-flex align-items-center justify-content-center min-vh-100 py-5">
        {# Conteneur principal agrandi, coins très arrondis (rounded-4), et séparé #}
        <div class="row w-100 shadow-lg bg-white rounded-4 overflow-hidden" style="max-width: 1400px; min-height: 90vh;">

            {# ----------------------------------------------------- #}
            {# COLONNE 1 : Le Formulaire d'Inscription (Gauche) #}
            {# Modification : Suppression de 'justify-content-center' pour remonter le contenu, utilisation de 'p-5' pour le padding. #}
            <div class="col-12 col-lg-6 d-flex flex-column p-3 p-md-4 p-lg-5 auth-form-col border-end">

                {# Modification : Centrage du titre et augmentation de la marge basse. #}
                <h1 class="mb-5 text-center h3">Créer mon compte Étudiant</h1>

                {# Affichage des erreurs globales #}
                {{ form_errors(registrationForm) }}

                {# Formulaire Centré dans la colonne pour une meilleure lecture #}
                <div class="mx-auto w-100" style="max-width: 450px;">
                    {{ form_start(registrationForm) }}

                    <div class="mb-3">
                        {# Email Lycée #}
                        {{ form_row(registrationForm.email, {
                            'attr': {'class': 'form-control', 'placeholder': 'prenom.nom@lycee-faure.fr'},
                            'label': 'Email du Lycée'
                        }) }}
                        <small class="form-text text-muted">Vous devez utiliser votre adresse @lycee-faure.fr</small>
                    </div>

                    <div class="mb-3">
                        {# Mot de passe #}
                        {{ form_row(registrationForm.plainPassword, {
                            'label': 'Mot de passe',
                            'attr': {'class': 'form-control'}
                        }) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.lastname, {
                            'label': 'Nom de famille',
                            'attr': {'class': 'form-control'}
                        }) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.firstname, {
                            'label': 'Prénom',
                            'attr': {'class': 'form-control'}
                        }) }}
                    </div>

                    <hr class="my-4">
                    <h5 class="mb-3 text-dark">Ma Scolarité</h5>

                    <div class="mb-3">
                        {# Classe/Niveau #}
                        {{ form_row(registrationForm.level, {
                            'label': 'Votre Classe',
                            'attr': {'class': 'form-select'}
                        }) }}
                    </div>

                    <div class="mb-3 mt-4">
                        {# Termes et conditions #}
                        {{ form_row(registrationForm.agreeTerms, {
                            'label': 'J\'accepte les conditions d\'utilisation'
                        }) }}
                    </div>

                    <button type="submit" class="btn btn-lg btn-primary w-100 mt-4">S'inscrire</button>
                    {{ form_end(registrationForm) }}
                </div>

                <div class="mt-3 text-center">
                    <p class="text-muted">Déjà un compte ? <a href="{{ path('app_login') }}" class="text-decoration-none">Se connecter</a></p>
                </div>
            </div>

            {# ----------------------------------------------------- #}
            {# COLONNE 2 : L'Image/Illustration (Droite) #}
            {# Ajout d'une marge à gauche sur mobile (mt-3) pour séparer le formulaire et l'image #}
            <div class="col-12 col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center p-5 text-white mt-3 mt-lg-0"
                 style="background-color: #007bff; background-image: url('{{ asset('img/themebleu.jpg') }}'); background-size: cover; background-position: center;">

            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script>
        new TomSelect('#registration_student_level', {
            placeholder: 'Rechercher ou choisir une classe...',
            allowEmptyOption: true,
            render: {
                no_results: function() {
                    return '<div class="no-results">Aucune classe trouvée</div>';
                }
            }
        });
    </script>
{% endblock %}
