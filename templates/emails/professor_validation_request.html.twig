{% extends 'emails/layout.html.twig' %}

{% block title %}Validation requise – Convention de stage – Conventio{% endblock %}

{% block badge %}Action requise{% endblock %}

{% block heading %}
    Une convention est prête<br>à être validée
{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">
        Bonjour <strong style="color:#1a1a2e;">{{ professor.firstname }} {{ professor.lastname }}</strong>,
    </p>

    <p style="margin:0 0 20px;font-size:15px;color:#495057;line-height:1.7;">
        Le tuteur en entreprise vient de compléter les informations administratives pour la convention de stage de votre étudiant(e).
        La convention est désormais <strong style="color:#0d6efd;">en attente de votre validation</strong>.
    </p>

    {# Récapitulatif de la convention #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;border-radius:12px;overflow:hidden;">
        <tr>
            <td style="background:#f8f9ff;border-radius:12px;padding:20px 24px;">
                <p style="margin:0 0 12px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6ea8fe;">Récapitulatif du stage</p>

                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td width="50%" style="padding:6px 0;border-bottom:1px solid #e9ecef;">
                            <span style="font-size:12px;color:#9ca3af;display:block;">Étudiant(e)</span>
                            <span style="font-size:14px;font-weight:600;color:#1a1a2e;">{{ contract.student.firstname }} {{ contract.student.lastname }}</span>
                        </td>
                        <td width="50%" style="padding:6px 0 6px 16px;border-bottom:1px solid #e9ecef;">
                            <span style="font-size:12px;color:#9ca3af;display:block;">Entreprise</span>
                            <span style="font-size:14px;font-weight:600;color:#1a1a2e;">{{ contract.organisation.name }}</span>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Connectez-vous à votre tableau de bord pour consulter les détails et valider la convention :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 8px;">
                <a href="{{ url('app_professor_show', {'id': professor.id}) }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:14px 32px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 18px rgba(13,110,253,0.35);">
                    Accéder à mon tableau de bord &rarr;
                </a>
            </td>
        </tr>
    </table>
{% endblock %}
