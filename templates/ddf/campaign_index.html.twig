{% extends 'base.html.twig' %}

{% block title %}Campagnes de stage{% endblock %}

{% block content %}
<style>
    .campaign-hero {
        background: linear-gradient(135deg, #14532d 0%, #22c55e 100%);
        border-radius: 16px;
        padding: 2rem 2.25rem;
        color: #fff;
        margin-bottom: 2rem;
    }
    .campaign-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 14px rgba(0,0,0,0.06);
        overflow: hidden;
    }
    .campaign-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.8rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
    }
    .period-pill {
        display: inline-flex;
        align-items: center;
        margin: 0 0.4rem 0.4rem 0;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: #eef4ff;
        color: #0d6efd;
        font-size: 0.78rem;
        font-weight: 600;
    }
    .btn-campaign {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 10px;
        padding: 0.45rem 0.85rem;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
    }
</style>

<main class="container py-5">
    <div class="campaign-hero d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-2"><i class="ph-bold ph-calendar-plus me-2"></i>Campagnes de stage</h1>
            <p class="mb-0" style="opacity:0.85;">La DDF pilote ici les périodes de stage par classe, y compris plusieurs segments pour une même campagne.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_ddf_contract_index') }}" class="btn btn-light btn-sm">Retour aux conventions</a>
            <a href="{{ path('app_ddf_campaign_new') }}" class="btn btn-dark btn-sm">Nouvelle campagne</a>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-3">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="campaign-card">
        {% if campaigns is empty %}
            <div class="p-5 text-center text-muted">
                <i class="ph ph-calendar-dashed" style="font-size:2rem;"></i>
                <p class="mt-3 mb-0">Aucune campagne n'a encore été créée.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Campagne</th>
                            <th>Classe</th>
                            <th>Périodes</th>
                            <th>État</th>
                            <th>Conventions liées</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for campaign in campaigns %}
                        <tr>
                            <td class="fw-semibold">{{ campaign.name }}</td>
                            <td>{{ campaign.level.levelName }}</td>
                            <td>
                                {% for period in campaign.sessionDates %}
                                    <span class="period-pill">{{ period.startDate|date('d/m/Y') }} → {{ period.endDate|date('d/m/Y') }}</span>
                                {% endfor %}
                            </td>
                            <td>
                                {% if campaign.isActive %}
                                    <span class="campaign-tag" style="background:#dcfce7;color:#166534;">
                                        <i class="ph ph-check-circle"></i>Active
                                    </span>
                                {% else %}
                                    <span class="campaign-tag" style="background:#f1f5f9;color:#475569;">
                                        <i class="ph ph-pause-circle"></i>Inactive
                                    </span>
                                {% endif %}
                            </td>
                            <td>{{ campaign.contracts|length }}</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ path('app_ddf_campaign_edit', {'id': campaign.id}) }}" class="btn-campaign btn btn-outline-primary btn-sm">
                                        <i class="ph ph-pencil-simple"></i>Modifier
                                    </a>
                                    <form method="post" action="{{ path('app_ddf_campaign_sync_contracts', {'id': campaign.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('ddf_sync_campaign_contracts' ~ campaign.id) }}">
                                        <button type="submit" class="btn-campaign btn btn-outline-success btn-sm">
                                            <i class="ph ph-arrows-clockwise"></i>Resynchroniser
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
