{% extends 'emails/layout.html.twig' %}

{% block title %}Votre collecte a été complétée – Conventio{% endblock %}
{% block icon %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c3.33 1.67 8.67 1.67 12 0v-5"/></svg>{% endblock %}
{% block badge %}Collecte complétée{% endblock %}
{% block heading %}Votre collecte est prête<br>à être vérifiée{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">
        Bonjour <strong style="color:#1a1a2e;">{{ student.firstname }}</strong>,
    </p>

    <p style="margin:0 0 24px;font-size:15px;color:#495057;line-height:1.7;">
        Bonne nouvelle ! L'entreprise a complété les informations de votre collecte de stage.
        Elle est maintenant <strong style="color:#0d6efd;">en attente de votre vérification</strong> avant transmission à votre professeur référent.
    </p>

    {# Étapes à suivre #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f0f4ff;border-radius:12px;padding:20px 24px;">
                <p style="margin:0 0 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6ea8fe;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6ea8fe" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:5px;"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg> Prochaines étapes
                </p>
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="padding:7px 0;border-bottom:1px solid #dde6ff;">
                            <table cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="width:26px;height:26px;background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:50%;text-align:center;line-height:26px;font-size:12px;font-weight:700;color:#fff;vertical-align:middle;">1</td>
                                    <td style="padding-left:12px;font-size:14px;color:#1a1a2e;font-weight:600;vertical-align:middle;">Relire attentivement votre collecte</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:7px 0;border-bottom:1px solid #dde6ff;">
                            <table cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="width:26px;height:26px;background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:50%;text-align:center;line-height:26px;font-size:12px;font-weight:700;color:#fff;vertical-align:middle;">2</td>
                                    <td style="padding-left:12px;font-size:14px;color:#1a1a2e;font-weight:600;vertical-align:middle;">Vérifier que toutes les informations sont correctes</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:7px 0;">
                            <table cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="width:26px;height:26px;background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:50%;text-align:center;line-height:26px;font-size:12px;font-weight:700;color:#fff;vertical-align:middle;">3</td>
                                    <td style="padding-left:12px;font-size:14px;color:#1a1a2e;font-weight:600;vertical-align:middle;">Valider pour transmission au professeur</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Connectez-vous à votre tableau de bord pour consulter et valider votre collecte :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 16px;">
                <a href="{{ url('app_student_show', {'id': student.id}) }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:15px 36px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 20px rgba(13,110,253,0.4);">
                    Voir ma collecte &rarr;
                </a>
            </td>
        </tr>
    </table>
{% endblock %}
