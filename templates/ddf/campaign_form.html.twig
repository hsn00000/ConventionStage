{% extends 'base.html.twig' %}

{% block title %}{{ campaign.id ? 'Modifier le planning' : 'Nouveau planning' }}{% endblock %}

{% block content %}
<style>
    .campaign-form-shell { max-width: 980px; margin: 0 auto; }
    .campaign-form-card { background: #fff; border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); overflow: hidden; }
    .campaign-form-hero { background: linear-gradient(135deg, #14532d 0%, #22c55e 100%); color: #fff; padding: 2rem 2.25rem; position: relative; overflow: hidden; }
    .campaign-form-hero::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.16) 1px, transparent 1px); background-size: 20px 20px; pointer-events: none; }
    .campaign-form-hero > * { position: relative; z-index: 1; }
    .campaign-form-body { padding: 2rem 2.25rem 2.25rem; background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%); }
    .campaign-section { background: #fff; border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); padding: 1.5rem; margin-bottom: 1.5rem; }
    .period-row { border: 1px solid rgba(13,110,253,0.12); border-radius: 14px; padding: 1rem; margin-bottom: 0.85rem; background: #fff; }
</style>

<main class="container py-5">
    <div class="campaign-form-shell">
        <div class="campaign-form-card">
            <div class="campaign-form-hero d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h1 class="h3 mb-2"><i class="ph-bold ph-calendar-plus me-2"></i>{{ campaign.id ? 'Modifier le planning' : 'Créer un planning de stage' }}</h1>
                    <p class="mb-0" style="opacity:0.85;">Définissez la classe concernée et une ou plusieurs périodes de convention.</p>
                </div>
                <a href="{{ path('app_ddf_campaign_index') }}" class="btn btn-light btn-sm">Retour</a>
            </div>

            <div class="campaign-form-body">
                {{ form_start(form) }}

                <div class="campaign-section">
                    <div class="row g-4">
                        <div class="col-md-6">{{ form_row(form.name) }}</div>
                        <div class="col-md-6">{{ form_row(form.level) }}</div>
                        <div class="col-12">{{ form_row(form.isActive) }}</div>
                    </div>
                </div>

                <div class="campaign-section">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="h5 mb-1">Périodes de stage</h2>
                            <p class="text-muted mb-0">Ajoutez plusieurs segments si le stage est interrompu.</p>
                        </div>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="add-period">Ajouter une période</button>
                    </div>

                    <div id="campaign-periods" data-prototype="{{ form_widget(form.internshipDates.vars.prototype)|e('html_attr') }}" data-index="{{ form.internshipDates|length }}">
                        {% for periodForm in form.internshipDates %}
                            <div class="period-row">
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-5">{{ form_row(periodForm.startDate) }}</div>
                                    <div class="col-md-5">{{ form_row(periodForm.endDate) }}</div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn btn-outline-danger btn-sm w-100 remove-period">Supprimer</button>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {{ form_errors(form.internshipDates) }}
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a href="{{ path('app_ddf_campaign_index') }}" class="btn btn-outline-secondary">Annuler</a>
                    <button type="submit" class="btn btn-primary">{{ campaign.id ? 'Enregistrer' : 'Créer le planning' }}</button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const container = document.getElementById('campaign-periods');
        const addButton = document.getElementById('add-period');

        function wireRemoveButtons(scope) {
            scope.querySelectorAll('.remove-period').forEach((button) => {
                button.addEventListener('click', function () {
                    const row = button.closest('.period-row');
                    if (row) {
                        row.remove();
                    }
                });
            });
        }

        addButton.addEventListener('click', function () {
            const index = Number(container.dataset.index);
            const template = container.dataset.prototype.replaceAll('__period__', index.toString());
            const wrapper = document.createElement('div');
            wrapper.className = 'period-row';
            wrapper.innerHTML = template;
            const row = document.createElement('div');
            row.className = 'row g-3 align-items-end';

            Array.from(wrapper.children).forEach((child) => {
                const column = document.createElement('div');
                column.className = 'col-md-5';
                column.appendChild(child);
                row.appendChild(column);
            });

            const actions = document.createElement('div');
            actions.className = 'col-md-2';
            actions.innerHTML = '<button type="button" class="btn btn-outline-danger btn-sm w-100 remove-period">Supprimer</button>';
            row.appendChild(actions);

            wrapper.innerHTML = '';
            wrapper.appendChild(row);
            container.appendChild(wrapper);
            container.dataset.index = (index + 1).toString();
            wireRemoveButtons(wrapper);
        });

        wireRemoveButtons(container);
    });
</script>
{% endblock %}
