{% extends 'base.html.twig' %}

{% block title %}Validation DDF{% endblock %}

{% block content %}
<style>
    .ddf-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #6ea8fe 100%);
        border-radius: 16px;
        padding: 2rem 2.5rem;
        color: #fff;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .ddf-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.18) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
    }
    .ddf-hero > * { position: relative; z-index: 1; }
    .ddf-hero h1 { font-weight: 800; letter-spacing: -0.03em; font-size: 1.8rem; }
    .ddf-hero p { opacity: 0.85; margin-bottom: 0; font-size: 0.95rem; }

    .stat-card {
        border: none;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.10); }
    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; flex-shrink: 0;
    }
    .stat-value { font-size: 1.6rem; font-weight: 800; line-height: 1; }
    .stat-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.6; margin-top: 2px; }

    .section-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .section-header {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        background: #fff;
    }
    .section-header .section-dot {
        width: 10px; height: 10px;
        border-radius: 50%; flex-shrink: 0;
    }
    .section-header h2 { font-size: 0.95rem; font-weight: 700; margin: 0; }
    .section-header .badge-count {
        margin-left: auto;
        font-size: 0.75rem;
        padding: 0.25em 0.65em;
        border-radius: 20px;
        font-weight: 600;
    }

    .empty-state {
        display: flex; flex-direction: column; align-items: center;
        padding: 3rem 1rem; color: #adb5bd; text-align: center;
    }
    .empty-state i { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .empty-state p { font-size: 0.875rem; margin: 0; }

    .table thead th {
        font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em;
        color: #6c757d; background: #f8f9fa;
        border-bottom: 1px solid #e9ecef; padding: 0.75rem 1rem;
    }
    .table tbody td { padding: 0.85rem 1rem; vertical-align: middle; font-size: 0.875rem; }
    .table tbody tr:last-child td { border-bottom: none; }
    .table tbody tr:hover td { background: #f8fbff; }

    .student-name { font-weight: 600; color: #212529; }
    .company-name { color: #495057; }
    .id-badge {
        display: inline-block;
        background: #e9ecef; color: #6c757d;
        font-size: 0.7rem; font-weight: 700;
        padding: 0.15em 0.55em; border-radius: 6px;
    }

    .signer-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 4px; font-size: 0.8rem; }
    .signer-list { display: flex; flex-direction: column; gap: 0.55rem; }
    .signer-row {
        display: grid;
        grid-template-columns: 92px minmax(180px, 1fr) 120px;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0;
        padding: 0.55rem 0.7rem;
        border-radius: 12px;
        background: #f8fbff;
        border: 1px solid #e2ecff;
        font-size: 0.82rem;
    }
    .signer-role {
        color: #52607a;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.69rem;
    }
    .signer-name {
        min-width: 0;
        font-weight: 600;
        color: #1f2937;
        line-height: 1.35;
        overflow-wrap: anywhere;
    }
    .status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 112px;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        border: 1px solid transparent;
        box-shadow: inset 0 -1px 0 rgba(255,255,255,0.18);
    }
    .status-pill-complete {
        background: #dff7e8;
        color: #0f7b3e;
        border-color: #b8ebcb;
    }
    .status-pill-notified {
        background: #fff1cc;
        color: #9a6700;
        border-color: #ffe08a;
    }
    .status-pill-pending {
        background: #eef2f7;
        color: #52607a;
        border-color: #d6deea;
    }
    .request-status-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        background: #e8f0fe;
        color: #1a56db;
        font-size: 0.78rem;
        font-weight: 800;
        border: 1px solid #cfe0ff;
    }
    .sync-meta {
        margin-left: auto;
        font-size: 0.72rem;
        color: #6c757d;
        font-weight: 600;
    }

    @media (max-width: 991.98px) {
        .sync-meta {
            width: 100%;
            margin-left: 0;
            margin-top: 0.35rem;
        }
        .signer-row {
            grid-template-columns: 1fr;
            gap: 0.35rem;
        }
        .status-pill {
            width: 100%;
        }
    }

    .code-id {
        font-family: monospace; font-size: 0.72rem;
        background: #f1f3f5; padding: 2px 6px;
        border-radius: 4px; color: #495057;
        max-width: 120px; overflow: hidden;
        text-overflow: ellipsis; white-space: nowrap;
        display: inline-block; vertical-align: middle;
    }

    .btn-action {
        border-radius: 8px; font-size: 0.8rem; font-weight: 600;
        padding: 0.4rem 0.8rem; border: 1.5px solid transparent;
        transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 5px;
    }
    .btn-action-primary { background: #0d6efd; color: #fff; border-color: #0d6efd; }
    .btn-action-primary:hover { background: #0b5ed7; color: #fff; transform: translateY(-1px); }
    .btn-action-outline { background: transparent; color: #0d6efd; border-color: rgba(13,110,253,0.35); }
    .btn-action-outline:hover { background: rgba(13,110,253,0.07); color: #0d6efd; }
    .btn-action-muted { background: transparent; color: #6c757d; border-color: rgba(0,0,0,0.15); }
    .btn-action-muted:hover { background: #f8f9fa; color: #495057; }
    .btn-action-success { background: transparent; color: #198754; border-color: rgba(25,135,84,0.35); }
    .btn-action-success:hover { background: rgba(25,135,84,0.07); color: #198754; }
    .btn-action-final {
        background: linear-gradient(135deg, #198754, #33b074);
        color: #fff;
        border-color: #198754;
        box-shadow: 0 8px 18px rgba(25,135,84,0.22);
    }
    .btn-action-final:hover { background: linear-gradient(135deg, #157347, #279764); color: #fff; transform: translateY(-1px); }
    .action-help {
        font-size: 0.72rem;
        line-height: 1.4;
        color: #5c677d;
    }
</style>

<main class="container py-5">

    {# HERO #}
    <div class="ddf-hero d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h1 class="mb-1"><i class="ph-bold ph-file-signature me-2"></i>Validation DDF</h1>
            <p>Validation administrative, génération du PDF et envoi à la signature électronique.</p>
        </div>
        <div class="d-flex gap-3 flex-wrap align-items-center">
            <div class="text-center">
                <div style="font-size:2rem;font-weight:800;">{{ contracts_to_validate|length }}</div>
                <div style="font-size:0.75rem;opacity:0.8;">À valider</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.3)"></div>
            <div class="text-center">
                <div style="font-size:2rem;font-weight:800;">{{ signature_in_progress|length }}</div>
                <div style="font-size:0.75rem;opacity:0.8;">En signature</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.3)"></div>
            <div class="text-center">
                <div style="font-size:2rem;font-weight:800;">{{ signed_contracts|length }}</div>
                <div style="font-size:0.75rem;opacity:0.8;">Finalisées</div>
            </div>
        </div>
    </div>

    {# FLASH MESSAGES #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show mb-3" role="alert">
                <i class="ph-bold {{ label == 'error' or label == 'danger' ? 'ph-warning' : (label == 'success' ? 'ph-check-circle' : 'ph-info') }} me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ACTIONS ADMIN #}
    <div class="d-flex align-items-center gap-3 p-3 mb-4 rounded-3" style="background:#eef4ff;border:1.5px solid #cfe2ff;">
        <div style="width:40px;height:40px;background:#0d6efd;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="ph-bold ph-calendar-plus" style="color:#fff;font-size:1.1rem;"></i>
        </div>
        <div class="flex-grow-1">
            <p class="mb-0 fw-bold" style="font-size:0.88rem;color:#1a1a2e;">Plannings de stage</p>
            <p class="mb-0" style="font-size:0.78rem;color:#5c677d;">Définir les périodes de convention par classe</p>
        </div>
        <a href="{{ path('app_ddf_campaign_index') }}" class="btn btn-primary btn-sm rounded-pill px-4 fw-semibold flex-shrink-0">
            <i class="ph ph-calendar-plus me-1"></i> Gérer les dates
        </a>
    </div>

    {# ── SECTION 1 : À VALIDER ────────────────────────────────────────────── #}
    <div class="section-card">
        <div class="section-header">
            <span class="section-dot" style="background:#fd7e14"></span>
            <h2>Conventions à valider</h2>
            <span class="badge-count badge" style="background:rgba(253,126,20,0.12);color:#fd7e14;">
                {{ contracts_to_validate|length }}
            </span>
        </div>
        <div class="card-body p-0">
            {% if contracts_to_validate is empty %}
                <div class="empty-state">
                    <i class="ph ph-check-circle" style="color:#20c997"></i>
                    <p>Aucune convention en attente de validation DDF.</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Étudiant</th>
                                <th>Entreprise</th>
                                <th>Professeur</th>
                                <th>PDF</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for contract in contracts_to_validate %}
                            <tr>
                                <td><span class="id-badge">#{{ contract.id }}</span></td>
                                <td>
                                    <span class="student-name">
                                        <i class="ph ph-student me-1 text-muted"></i>
                                        {{ contract.student.firstname }} {{ contract.student.lastname }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-buildings me-1 text-muted"></i>
                                        {{ contract.organisation.name }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-chalkboard-teacher me-1 text-muted"></i>
                                        {{ contract.coordinator.firstname }} {{ contract.coordinator.lastname }}
                                    </span>
                                </td>
                                <td>
                                    <span class="text-muted small">Disponible après validation DDF</span>
                                </td>
                                <td>
                                    <a href="{{ path('app_ddf_contract_validate', {'id': contract.id}) }}" class="btn-action btn-action-primary">
                                        <i class="ph ph-eye"></i> Visualiser
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    {# ── SECTION 2 : VALIDÉES PAR LA DDF ─────────────────────────────────── #}
    <div class="section-card">
        <div class="section-header">
            <span class="section-dot" style="background:#20c997"></span>
            <h2>Conventions validées par la DDF</h2>
            <span class="badge-count badge" style="background:rgba(32,201,151,0.12);color:#198754;">
                {{ validated_contracts|length }}
            </span>
        </div>
        <div class="card-body p-0">
            {% if validated_contracts is empty %}
                <div class="empty-state">
                    <i class="ph ph-file-arrow-up" style="color:#20c997"></i>
                    <p>Aucune convention validée en attente de génération.</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Étudiant</th>
                                <th>Entreprise</th>
                                <th>Professeur</th>
                                <th>PDF</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for contract in validated_contracts %}
                            <tr>
                                <td><span class="id-badge">#{{ contract.id }}</span></td>
                                <td>
                                    <span class="student-name">
                                        <i class="ph ph-student me-1 text-muted"></i>
                                        {{ contract.student.firstname }} {{ contract.student.lastname }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-buildings me-1 text-muted"></i>
                                        {{ contract.organisation.name }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-chalkboard-teacher me-1 text-muted"></i>
                                        {{ contract.coordinator.firstname }} {{ contract.coordinator.lastname }}
                                    </span>
                                </td>
                                <td>
                                    {% if contract.pdfUnsigned %}
                                        <a href="{{ path('app_ddf_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-action btn-action-outline">
                                            <i class="ph ph-eye"></i> Voir
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">À générer</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <form method="post" action="{{ path('app_ddf_contract_generate_and_send', {'id': contract.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('ddf_generate_and_send_contract' ~ contract.id) }}">
                                        <button class="btn-action btn-action-primary" type="submit">
                                            <i class="ph ph-paper-plane-tilt"></i> Générer & envoyer
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    {# ── SECTION 3 : SIGNATURES EN COURS ─────────────────────────────────── #}
    <div class="section-card">
        <div class="section-header">
            <span class="section-dot" style="background:#0d6efd"></span>
            <h2>Signatures en cours</h2>
            <span class="sync-meta">Actualisation auto toutes les 30 s. Dernière lecture: {{ 'now'|date('H:i:s') }}</span>
            <span class="badge-count badge" style="background:rgba(13,110,253,0.1);color:#0d6efd;">
                {{ signature_in_progress|length }}
            </span>
        </div>
        <div class="card-body p-0">
            {% if signature_in_progress is empty %}
                <div class="empty-state">
                    <i class="ph ph-signature"></i>
                    <p>Aucune signature en cours.</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Étudiant</th>
                                <th>Entreprise</th>
                                <th>PDF</th>
                                <th>Statut & signataires</th>
                                <th>Il manque</th>
                                <th>Identifiants YouSign</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for contract in signature_in_progress %}
                            {% set signature_status = signature_statuses[contract.id] ?? null %}
                            <tr>
                                <td><span class="id-badge">#{{ contract.id }}</span></td>
                                <td>
                                    <span class="student-name">
                                        <i class="ph ph-student me-1 text-muted"></i>
                                        {{ contract.student.firstname }} {{ contract.student.lastname }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-buildings me-1 text-muted"></i>
                                        {{ contract.organisation.name }}
                                    </span>
                                </td>
                                <td>
                                    {% if contract.pdfUnsigned %}
                                        <a href="{{ path('app_ddf_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-action btn-action-outline">
                                            <i class="ph ph-eye"></i> Voir
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">N/A</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if signature_status and signature_status.error is not defined %}
                                        <div class="mb-2">
                                            <span class="request-status-pill">
                                                {{ signature_status.request_status_label }}
                                            </span>
                                        </div>
                                        <div class="signer-list">
                                            {% for signer in signature_status.signers %}
                                                <div class="signer-row">
                                                    <span class="signer-role">{{ signer.role }}</span>
                                                    <span class="signer-name">{{ signer.name ?: (signer.email ?: 'Inconnu') }}</span>
                                                    <span class="status-pill {{ signer.is_complete ? 'status-pill-complete' : (signer.status == 'notified' ? 'status-pill-notified' : 'status-pill-pending') }}">
                                                        {{ signer.status_label }}
                                                    </span>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% elseif signature_status and signature_status.error is defined %}
                                        <span class="text-danger small"><i class="ph ph-warning me-1"></i>{{ signature_status.error }}</span>
                                    {% else %}
                                        <span class="text-muted small">Indisponible</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if signature_status and signature_status.error is not defined %}
                                        {% if signature_status.missing_signers is empty %}
                                            <span style="color:#198754;font-size:0.8rem;font-weight:600;">
                                                <i class="ph ph-check me-1"></i>Complet
                                            </span>
                                        {% else %}
                                            <span style="color:#fd7e14;font-size:0.8rem;">
                                                <i class="ph ph-clock me-1"></i>{{ signature_status.missing_signers|join(', ') }}
                                            </span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted small">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="font-size:0.72rem;color:#6c757d;margin-bottom:3px;">
                                        <span style="opacity:0.6;">Req.</span>
                                        <span class="code-id" title="{{ contract.yousignSignatureRequestId ?: 'N/A' }}">
                                            {{ contract.yousignSignatureRequestId ?: 'N/A' }}
                                        </span>
                                    </div>
                                    <div style="font-size:0.72rem;color:#6c757d;">
                                        <span style="opacity:0.6;">Doc.</span>
                                        <span class="code-id" title="{{ contract.yousignDocumentId ?: 'N/A' }}">
                                            {{ contract.yousignDocumentId ?: 'N/A' }}
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <form method="post" action="{{ path('app_ddf_contract_resend_signature_notification', {'id': contract.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('ddf_resend_signature_notification' ~ contract.id) }}">
                                            <button class="btn-action btn-action-primary" type="submit">
                                                <i class="ph ph-paper-plane-tilt"></i> Renvoyer notification
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('app_ddf_contract_sync_signed_document', {'id': contract.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('ddf_sync_contract' ~ contract.id) }}">
                                            <button class="btn-action btn-action-final" type="submit">
                                                <i class="ph ph-download-simple"></i> Document final envoyé à toutes les parties par mail via webhook
                                            </button>
                                        </form>
                                        <div class="action-help">
                                            À utiliser quand la signature YouSign est terminée pour récupérer la version finale signée.
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    {# ── SECTION 3 : SIGNATURES FINALISÉES ───────────────────────────────── #}
    <div class="section-card">
        <div class="section-header">
            <span class="section-dot" style="background:#198754"></span>
            <h2>Signatures finalisées</h2>
            <span class="badge-count badge" style="background:rgba(25,135,84,0.1);color:#198754;">
                {{ signed_contracts|length }}
            </span>
        </div>
        <div class="card-body p-0">
            {% if signed_contracts is empty %}
                <div class="empty-state">
                    <i class="ph ph-seal-check"></i>
                    <p>Aucune convention signée pour le moment.</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Étudiant</th>
                                <th>Entreprise</th>
                                <th>PDF signé</th>
                                <th>Identifiants YouSign</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for contract in signed_contracts %}
                            <tr>
                                <td><span class="id-badge">#{{ contract.id }}</span></td>
                                <td>
                                    <span class="student-name">
                                        <i class="ph ph-student me-1 text-muted"></i>
                                        {{ contract.student.firstname }} {{ contract.student.lastname }}
                                    </span>
                                </td>
                                <td>
                                    <span class="company-name">
                                        <i class="ph ph-buildings me-1 text-muted"></i>
                                        {{ contract.organisation.name }}
                                    </span>
                                </td>
                                <td>
                                    {% if contract.pdfSigned or contract.pdfUnsigned %}
                                        <a href="{{ path('app_ddf_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-action btn-action-success">
                                            <i class="ph ph-file-pdf"></i> Voir le PDF signé
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">N/A</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="font-size:0.72rem;color:#6c757d;margin-bottom:3px;">
                                        <span style="opacity:0.6;">Req.</span>
                                        <span class="code-id" title="{{ contract.yousignSignatureRequestId ?: 'N/A' }}">
                                            {{ contract.yousignSignatureRequestId ?: 'N/A' }}
                                        </span>
                                    </div>
                                    <div style="font-size:0.72rem;color:#6c757d;">
                                        <span style="opacity:0.6;">Doc.</span>
                                        <span class="code-id" title="{{ contract.yousignDocumentId ?: 'N/A' }}">
                                            {{ contract.yousignDocumentId ?: 'N/A' }}
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

</main>
<script>
    window.setTimeout(() => window.location.reload(), 30000);
</script>
{% endblock %}
