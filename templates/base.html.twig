{% set is_logged_in = is_granted('IS_AUTHENTICATED_FULLY') %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Conventio - Conventions de Stage{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {# Assurez-vous que le CSS et le JS de Bootstrap sont chargés via votre importmap #}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% block stylesheets %}
        {# Ajout de Font Awesome pour les icônes (détecté via contract/new.html.twig) #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" integrity="sha512-1y6w3t9V8J5uH3p3O5E6T4+r7L7IqU5F2Yx+m4J1eR/1g+K1I/3w5E3+qF8D6O5L3t3v6W5U7r9X7L7/8g7T7r4w==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        {# Vous pouvez ajouter ici votre CSS personnalisé si besoin #}
    {% endblock %}
</head>
<body>
{% block body %}

    {# --------------------------------------------------------------------- #}
    {# NAVIGATION BAR BOOTSTRAP 5 (Non fixée et avec marges latérales) #}
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
        <div class="container">
            {# LOGO / MARQUE #}
            <a href="{{ path('app_home') }}" class="navbar-brand">
                <span class="fw-bold text-dark">Conventio</span>
            </a>

            {# BOUTON POUR MOBILE (Hamburger) #}
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavActions" aria-controls="navbarNavActions" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            {# ÉLÉMENTS DE NAVIGATION ET BOUTONS À DROITE #}
            <div class="collapse navbar-collapse justify-content-end" id="navbarNavActions">
                <ul class="navbar-nav align-items-center">

                    {% if not is_logged_in %}
                        {# Liens d'Inscription #}
                        <li class="nav-item me-3 mb-2 mb-lg-0">
                            <a href="{{ path('app_register_student') }}" class="nav-link text-muted">Étudiant</a>
                        </li>
                        <li class="nav-item me-3 mb-2 mb-lg-0">
                            <a href="{{ path('app_register_professor') }}" class="nav-link text-muted">Professeur</a>
                        </li>
                        {# Bouton Se connecter #}
                        <li class="nav-item">
                            <a href="{{ path('app_login') }}" class="btn btn-primary shadow-sm">Se connecter</a>
                        </li>
                    {% else %}

                        {# --- MODIFICATION ICI : Bouton Admin --- #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item me-2 mb-2 mb-lg-0">
                                <a href="{{ path('app_ddf_contract_index') }}" class="btn btn-dark">
                                    <i class="fas fa-file-signature me-1"></i> DDF
                                </a>
                            </li>
                            <li class="nav-item me-2 mb-2 mb-lg-0">
                                <a href="{{ path('app_admin_level_index') }}" class="btn btn-outline-dark">
                                    <i class="fas fa-cog me-1"></i> Admin
                                </a>
                            </li>
                        {% endif %}
                        {# --------------------------------------- #}

                        {# --- Éléments du Dashboard pour Utilisateur Connecté --- #}

                        {# 1. Bouton Profil pour Professeur #}
                        {% if is_granted('ROLE_PROFESSOR') and app.user.id is defined %}
                            <li class="nav-item me-2 mb-2 mb-lg-0">
                                <a href="{{ path('app_professor_show', {'id': app.user.id}) }}" class="btn btn-secondary">
                                    <i class="fas fa-user-circle me-1"></i> Profil
                                </a>
                            </li>
                        {% endif %}

                        {# 2. Bouton Profil pour Étudiant #}
                        {% if is_granted('ROLE_STUDENT') and app.user.id is defined %}
                            <li class="nav-item me-2 mb-2 mb-lg-0">
                                <a href="{{ path('app_student_show', {'id': app.user.id}) }}" class="btn btn-secondary">
                                    <i class="fas fa-user-circle me-1"></i> Profil
                                </a>
                            </li>
                        {% endif %}

                        {# Bouton Se déconnecter #}
                        <li class="nav-item">
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Se déconnecter</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
    {# --------------------------------------------------------------------- #}

    {# --------------------------------------------------------------------- #}
    {# BLOC CONTENT : Ce contenu sera affiché par défaut ou remplacé par les pages enfants #}
    {# --------------------------------------------------------------------- #}
    {% block content %}
        <main class="container-fluid d-flex align-items-center justify-content-center vh-100 py-5">
            <div class="row w-100 two-column-layout align-items-center justify-content-center">

                {# Colonne de Contenu (La Carte) #}
                <div class="col-12 col-lg-6 content-side order-2 order-lg-1">
                    <div class="card border-secondary mb-3 mx-auto shadow-lg" style="max-width: 30rem;">

                        <div class="card-header bg-secondary text-white">
                            <h1 class="h4 mb-0">Bienvenue sur Conventio 👋</h1>
                        </div>

                        <div class="card-body text-secondary p-4 p-md-5">
                            <h5 class="card-title text-dark">Simplifiez la gestion de vos Conventions de Stage en quelques clics.</h5>
                            <p class="card-text description mt-3">
                                Que vous soyez étudiant, professeur ou responsable d'entreprise,
                                notre plateforme centralise tous les documents et le suivi nécessaire
                                pour des stages réussis.
                            </p>
                            <a href="{{ path('app_register_student') }}" class="btn btn-primary btn-lg cta-button mt-4">Commencer maintenant</a>
                        </div>
                    </div>
                </div>

                {# Colonne du Logo/Image #}
                <div class="col-12 col-lg-6 logo-side order-1 order-lg-2 text-center mb-4 mb-lg-0">
                    <div class="logo-wrapper p-3">
                        <img src="{{ asset('img/Conventio.png') }}" alt="Logo de Conventio" class="main-illustration img-fluid" style="max-height: 40vh;">
                    </div>
                </div>

            </div>
        </main>
    {% endblock %}
    {# --------------------------------------------------------------------- #}

{% endblock %}
</body>
</html>
