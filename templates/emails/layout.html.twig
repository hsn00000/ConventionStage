<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Conventio{% endblock %}</title>
    <!--[if mso]>
    <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
    <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f0f4ff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f4ff;padding:40px 16px;">
<tr><td align="center">

    <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        {# ── LOGO ── #}
        <tr>
            <td align="center" style="padding-bottom:28px;">
                <table cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:linear-gradient(135deg,#0d6efd 0%,#6ea8fe 100%);border-radius:14px;padding:11px 24px;">
                            <span style="color:#ffffff;font-size:18px;font-weight:800;letter-spacing:0.05em;">&#10022; Conventio</span>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        {# ── CARTE PRINCIPALE ── #}
        <tr>
            <td style="background:#ffffff;border-radius:20px;box-shadow:0 4px 32px rgba(13,110,253,0.12);overflow:hidden;">

                {# Bande header avec dégradé + points #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td bgcolor="#0d6efd" style="background:#0d6efd;background:linear-gradient(120deg,#0a58ca 0%,#0d6efd 55%,#6ea8fe 100%);padding:32px 40px 28px;">

                            {# Icône centrée #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td align="center" style="padding-bottom:8px;">
                                        <table cellpadding="0" cellspacing="0" border="0" align="center" style="background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.35);border-radius:50%;">
                                            <tr>
                                                <td width="56" height="56" align="center" valign="middle" style="border-radius:50%;">
                                                    {% block icon %}
                                                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                                    {% endblock %}
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <div style="display:inline-block;background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.3);border-radius:50px;padding:5px 16px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#fff;">
                                            {% block badge %}Lycée Gabriel Fauré{% endblock %}
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding-top:8px;">
                                        <h1 style="margin:0;font-size:22px;font-weight:800;color:#ffffff;line-height:1.35;text-align:center;">
                                            {% block heading %}{% endblock %}
                                        </h1>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>
                </table>

                {# Corps du message #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="padding:32px 40px 0;">
                            {% block body %}{% endblock %}
                        </td>
                    </tr>
                </table>

                {# Bouton CTA #}
                {% block cta %}{% endblock %}

                {# Séparateur & signature #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="padding:28px 40px 0;">
                            <hr style="border:none;border-top:1px solid #e9ecef;margin:0;">
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 40px 36px;">
                            <table cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="width:3px;background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:3px;">&nbsp;</td>
                                    <td style="padding-left:12px;">
                                        <p style="margin:0;font-size:13px;color:#6c757d;line-height:1.7;">
                                            Cordialement,<br>
                                            <strong style="color:#1a1a2e;font-size:14px;">L'équipe administrative<br>du Lycée Gabriel Fauré</strong>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>

        {# ── PIED DE PAGE ── #}
        <tr>
            <td align="center" style="padding-top:28px;">
                <p style="margin:0 0 6px;font-size:11px;color:#9ca3af;line-height:1.8;">
                    Cet email a été envoyé automatiquement par <strong style="color:#6b7280;">Conventio</strong>.<br>
                    Merci de ne pas répondre directement à ce message.
                </p>
                <p style="margin:0;font-size:10px;color:#c4c9d4;">
                    &copy; Lycée Gabriel Fauré — Plateforme de gestion des conventions de stage
                </p>
            </td>
        </tr>

    </table>

</td></tr>
</table>

</body>
</html>
