{% extends 'emails/layout.html.twig' %}

{% block title %}Confirmez votre adresse email – Conventio{% endblock %}
{% block icon %}✉️{% endblock %}
{% block badge %}Vérification du compte{% endblock %}
{% block heading %}Bienvenue sur Conventio !<br><span style="font-size:17px;font-weight:500;opacity:0.85;">Confirmez votre adresse email</span>{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">Bonjour,</p>

    <p style="margin:0 0 24px;font-size:15px;color:#495057;line-height:1.7;">
        Merci de vous être inscrit(e) sur <strong style="color:#0d6efd;">Conventio</strong>, la plateforme de gestion des conventions de stage du <strong style="color:#1a1a2e;">Lycée Gabriel Fauré</strong>.
    </p>

    {# Bloc info #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f0f4ff;border-radius:12px;padding:18px 20px;">
                <table cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="font-size:22px;vertical-align:top;padding-right:14px;">🔐</td>
                        <td>
                            <p style="margin:0 0 4px;font-size:13px;font-weight:700;color:#1a1a2e;">Une étape manquante</p>
                            <p style="margin:0;font-size:13px;color:#495057;line-height:1.6;">
                                Votre compte est créé mais pas encore actif. Confirmez votre adresse email pour accéder à tous les services de la plateforme.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Cliquez sur le bouton ci-dessous pour activer votre compte :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 16px;">
                <a href="{{ signedUrl|raw }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:15px 36px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 20px rgba(13,110,253,0.4);">
                    Confirmer mon adresse email &rarr;
                </a>
            </td>
        </tr>
        <tr>
            <td style="padding:0 40px 16px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:#fff8e1;border-left:4px solid #ffc107;border-radius:0 8px 8px 0;padding:12px 16px;">
                            <p style="margin:0;font-size:13px;color:#856404;line-height:1.6;">
                                ⏱ Ce lien expirera dans <strong>{{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}</strong>.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
{% endblock %}
