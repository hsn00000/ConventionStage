{% extends 'base.html.twig' %}

{% block title %}Dashboard Professeur - {{ professor.firstname }} {{ professor.lastname }}{% endblock %}

{% block content %}
    <main class="container py-5">

        {# --- En-tête du Dashboard --- #}
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <h1 class="h2 mb-0 text-primary">Tableau de Bord Professeur</h1>
            <p class="text-muted mb-0">Bienvenue, {{ professor.firstname }} {{ professor.lastname }}</p>
        </div>

        {# --- Messages Flash (Alerte Visuelle) --- #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {# --- 1. Cartes de Métriques Clés (KPIs) --- #}
        <div class="row mb-5 g-4">

            {# KPI 1: Conventions en Attente (Urgent) #}
            <div class="col-md-4">
                <div class="card shadow-sm border-danger border-3 rounded-3 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <span class="fs-1 me-3 text-danger">🚨</span>
                            <div>
                                <h6 class="card-subtitle mb-2 text-danger text-uppercase small fw-bold">Action Requise</h6>
                                <h3 class="card-title mb-0">{{ pending_validation_count }} Conventions</h3>
                            </div>
                        </div>
                        <p class="mt-3 mb-0 text-muted small">Cliquer ci-dessous pour voir la liste à valider.</p>
                    </div>
                </div>
            </div>

            {# KPI 2: Conventions Actives #}
            <div class="col-md-4">
                <div class="card shadow-sm border-success border-3 rounded-3 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <span class="fs-1 me-3 text-success">✅</span>
                            <div>
                                <h6 class="card-subtitle mb-2 text-success text-uppercase small fw-bold">Collectes Validees</h6>
                                <h3 class="card-title mb-0">{{ validated_collections_count }} Conventions</h3>
                            </div>
                        </div>
                        <p class="mt-3 mb-0 text-muted small">Collectes d'informations deja validees par vos soins.</p>
                    </div>
                </div>
            </div>

            {# KPI 3: Étudiants Supervisés #}
            <div class="col-md-4">
                <div class="card shadow-sm border-primary border-3 rounded-3 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <span class="fs-1 me-3 text-primary">🎓</span>
                            <div>
                                <h6 class="card-subtitle mb-2 text-primary text-uppercase small fw-bold">Vos Référents</h6>
                                <h3 class="card-title mb-0">{{ students_count }} Étudiants</h3>
                            </div>
                        </div>
                        <p class="mt-3 mb-0 text-muted small">Nombre total d'étudiants dont vous êtes référent.</p>
                    </div>
                </div>
            </div>

        </div>

        {# --- 2. Section: Conventions à Valider (La plus importante) --- #}
        <div class="row mb-5">
            <div class="col-12">
                <div class="card shadow rounded-3 border-danger">
                    <div class="card-header bg-danger text-white p-3">
                        <h4 class="mb-0">🚨 Conventions Nécessitant Votre Validation ({{ pending_validation_count }})</h4>
                    </div>

                    <div class="card-body p-0">
                        {% if pending_validation_count == 0 %}
                            {# Style amélioré pour l'alerte verte #}
                            <div class="p-4 bg-light-subtle rounded-bottom text-center">
                                <span class="text-success fs-4 me-2">👍</span>
                                <span class="fw-bold text-success">Toutes les conventions urgentes ont été traitées. Bon travail !</span>
                            </div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th class="py-3 px-3">ID</th>
                                        <th class="py-3 px-3">Étudiant</th>
                                        <th class="py-3 px-3">Entreprise</th>
                                        <th class="py-3 px-3">Statut</th>
                                        <th class="py-3 px-3" style="width: 250px;">Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for contract in contracts_to_validate %}
                                        <tr class="alert-danger-subtle">
                                            <td class="px-3">#{{ contract.id }}</td>
                                            <td class="px-3">
                                                <span class="fw-bold">{{ contract.student.firstname }} {{ contract.student.lastname }}</span>
                                            </td>
                                            <td class="px-3">{{ contract.organisation.name }}</td>
                                            <td class="px-3">
                                                <span class="badge bg-danger fw-bold py-2">ACTION REQUISE</span>
                                            </td>
                                            <td class="px-3">
                                                <a href="{{ path('app_professor_validate_contract', {'id': contract.id}) }}" class="btn btn-sm btn-success me-2">
                                                    Ouvrir et traiter
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# --- 3. Section: Collectes deja validees --- #}
        <div class="row mb-5">
            <div class="col-12">
                <div class="card shadow rounded-3 border-success">
                    <div class="card-header bg-success text-white p-3">
                        <h4 class="mb-0">✅ Collectes deja validees par vous ({{ validated_collections_count }})</h4>
                    </div>
                    <div class="card-body p-0">
                        {% if validated_collections is empty %}
                            <div class="p-4 bg-light-subtle rounded-bottom text-center">
                                <span class="text-muted">Aucune collecte validee pour le moment.</span>
                            </div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th class="py-3 px-3">ID</th>
                                        <th class="py-3 px-3">Etudiant</th>
                                        <th class="py-3 px-3">Entreprise</th>
                                        <th class="py-3 px-3">Etape actuelle</th>
                                        <th class="py-3 px-3">Acces</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for contract in validated_collections %}
                                        <tr>
                                            <td class="px-3">#{{ contract.id }}</td>
                                            <td class="px-3">
                                                <span class="fw-bold">{{ contract.student.firstname }} {{ contract.student.lastname }}</span>
                                            </td>
                                            <td class="px-3">{{ contract.organisation.name }}</td>
                                            <td class="px-3">
                                                {% set label = contract.statusLabel %}
                                                {% set badge_class = 'bg-success' %}
                                                {% if contract.status == 'validated_by_prof' %}
                                                    {% set label = 'En attente DDF' %}
                                                    {% set badge_class = 'bg-primary' %}
                                                {% elseif contract.status == 'validated_by_ddf' %}
                                                    {% set label = 'Pret pour signature' %}
                                                    {% set badge_class = 'bg-info text-dark' %}
                                                {% elseif contract.status == 'signature_requested' %}
                                                    {% set label = 'Signature en cours' %}
                                                    {% set badge_class = 'bg-dark' %}
                                                {% elseif contract.status == 'signed' %}
                                                    {% set label = 'Convention signee' %}
                                                    {% set badge_class = 'bg-success' %}
                                                {% endif %}
                                                <span class="badge {{ badge_class }} fw-bold py-2">{{ label }}</span>
                                            </td>
                                            <td class="px-3">
                                                <a href="{{ path('app_professor_validate_contract', {'id': contract.id}) }}" class="btn btn-sm btn-outline-success">Voir la collecte</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# --- 4. Section: Conventions en Suivi (Moins Urgent) --- #}
        <div class="row">
            <div class="col-12">
                <div class="card shadow rounded-3">
                    <div class="card-header bg-light p-3">
                        <h4 class="mb-0 text-secondary">Conventions en Suivi (En attente d'autres acteurs)</h4>
                    </div>
                    <div class="card-body p-0">
                        {% set pending_follow_up = all_coordinated_contracts|filter(c => c.status in ['collection_sent', 'filled_by_company', 'validated_by_prof', 'validated_by_ddf', 'signature_requested']) %}

                        {% if pending_follow_up is empty %}
                            <div class="alert alert-info m-3 mb-0" role="alert">
                                Aucune convention en attente de l'entreprise ou de l'étudiant.
                            </div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th class="py-3 px-3">ID</th>
                                        <th class="py-3 px-3">Étudiant</th>
                                        <th class="py-3 px-3">Entreprise</th>
                                        <th class="py-3 px-3">Statut</th>
                                        <th class="py-3 px-3">Progression</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for contract in pending_follow_up %}
                                        <tr>
                                            <td class="px-3">#{{ contract.id }}</td>
                                            <td class="px-3">{{ contract.student.firstname }} {{ contract.student.lastname }}</td>
                                            <td class="px-3">{{ contract.organisation.name }}</td>
                                            <td class="px-3">
                                                {% set label = 'En attente' %}
                                                {% set badge_class = 'bg-warning text-dark' %}
                                                {% if contract.status == 'collection_sent' %}
                                                    {% set label = 'Collecte envoyee' %}
                                                    {% set badge_class = 'bg-secondary' %}
                                                {% elseif contract.status == 'filled_by_company' %}
                                                    {% set label = 'Validation etudiant' %}
                                                    {% set badge_class = 'bg-info text-dark' %}
                                                {% elseif contract.status == 'validated_by_prof' %}
                                                    {% set label = 'Validation DDF' %}
                                                    {% set badge_class = 'bg-primary' %}
                                                {% elseif contract.status == 'validated_by_ddf' %}
                                                    {% set label = 'Pret pour signature' %}
                                                    {% set badge_class = 'bg-primary' %}
                                                {% elseif contract.status == 'signature_requested' %}
                                                    {% set label = 'Signature en cours' %}
                                                    {% set badge_class = 'bg-dark' %}
                                                {% endif %}
                                                <span class="badge {{ badge_class }} fw-bold py-2">{{ label }}</span>
                                            </td>
                                            <td class="px-3">
                                                <a href="{{ path('app_professor_validate_contract', {'id': contract.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# --- 5. Section: Mon Profil (Informations Détaillées) --- #}
        <div class="card shadow-sm mt-5 rounded-3">
            <div class="card-header bg-light p-3">
                <h4 class="mb-0 text-secondary">Mon Profil & Sécurité</h4>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p><strong>Nom :</strong> {{ professor.lastname }}</p>
                        <p><strong>Prénom :</strong> {{ professor.firstname }}</p>
                        <p><strong>Email :</strong> {{ professor.email }}</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        {# Remplacement du bouton "Modifier mes informations" par "Modifier le mot de passe" #}
                        {# La route app_forgot_password_request renvoie vers le formulaire de demande de réinitialisation. #}
                        <a href="{{ path('app_forgot_password_request') }}" class="btn btn-warning">
                            Modifier le mot de passe
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </main>
{% endblock %}
