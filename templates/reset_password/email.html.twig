{% extends 'emails/layout.html.twig' %}

{% block title %}Réinitialisation de mot de passe – Conventio{% endblock %}
{% block icon %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>{% endblock %}
{% block badge %}Sécurité du compte{% endblock %}
{% block heading %}Réinitialisez votre<br>mot de passe{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">Bonjour,</p>

    <p style="margin:0 0 24px;font-size:15px;color:#495057;line-height:1.7;">
        Nous avons reçu une demande de réinitialisation du mot de passe associé à votre compte sur la plateforme
        <strong style="color:#0d6efd;">Conventio</strong>.
    </p>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Cliquez sur le bouton ci-dessous pour définir un nouveau mot de passe :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 16px;">
                <a href="{{ url('app_reset_password', {token: resetToken.token}) }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:15px 36px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 20px rgba(13,110,253,0.4);">
                    Réinitialiser mon mot de passe &rarr;
                </a>
            </td>
        </tr>
        <tr>
            <td style="padding:0 40px 8px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:#fff8e1;border-left:4px solid #ffc107;border-radius:0 8px 8px 0;padding:12px 16px;">
                            <p style="margin:0;font-size:13px;color:#856404;line-height:1.6;">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#856404" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:5px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Ce lien est valide pendant <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td style="padding:8px 40px 16px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:#fef2f2;border-left:4px solid #ef4444;border-radius:0 8px 8px 0;padding:12px 16px;">
                            <p style="margin:0;font-size:13px;color:#991b1b;line-height:1.6;">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#991b1b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:5px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Si vous n'êtes pas à l'origine de cette demande, ignorez cet email. Votre mot de passe ne sera pas modifié.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
{% endblock %}
