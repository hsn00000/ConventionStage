{# templates/student/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord{% endblock %}

{% block content %}
<style>
    /* ── HERO ─────────────────────────────────────────────────────────── */
    .student-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #6ea8fe 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        color: #fff;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        position: relative;
        overflow: hidden;
    }
    .student-hero::before {
        content: '';
        position: absolute; inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.18) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
    }
    .student-hero > * { position: relative; z-index: 1; }
    .student-hero-avatar {
        width: 56px; height: 56px;
        background: rgba(255,255,255,0.2);
        border: 2px solid rgba(255,255,255,0.35);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; font-weight: 800; color: #fff;
        flex-shrink: 0;
    }
    .student-hero h1 { font-weight: 800; font-size: 1.5rem; letter-spacing: -0.02em; margin: 0; }
    .student-hero p  { opacity: 0.75; margin: 0.25rem 0 0; font-size: 0.875rem; }
    .hero-cta {
        background: #fff;
        color: #0d6efd;
        border: none;
        border-radius: 50px;
        padding: 0.6rem 1.4rem;
        font-weight: 700;
        font-size: 0.875rem;
        display: inline-flex; align-items: center; gap: 6px;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        white-space: nowrap;
    }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); color: #0b5ed7; }

    /* ── STAT CARDS ───────────────────────────────────────────────────── */
    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
    @media (max-width: 767px) { .stat-grid { grid-template-columns: 1fr; } }

    .stat-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        padding: 1.35rem 1.5rem;
        display: flex; align-items: center; gap: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.09); }
    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; flex-shrink: 0;
    }
    .stat-value { font-size: 1.75rem; font-weight: 800; line-height: 1; color: #1a1a2e; }
    .stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #6c757d; margin-top: 3px; }

    /* ── SECTION BLOCKS ──────────────────────────────────────────────── */
    .contracts-section {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }
    .contracts-header {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .contracts-header .section-dot {
        width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .contracts-header h2 { font-size: 0.92rem; font-weight: 700; margin: 0; color: #1a1a2e; }
    .contracts-header .badge-count {
        margin-left: auto;
        font-size: 0.73rem; padding: 0.22em 0.65em;
        border-radius: 20px; font-weight: 700;
    }

    .contract-item {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        transition: background 0.15s ease;
    }
    .contract-item:last-child { border-bottom: none; }
    .contract-item:hover { background: #f8fbff; }

    .contract-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .contract-company { font-weight: 700; font-size: 1rem; color: #1a1a2e; }
    .contract-id { font-size: 0.72rem; font-weight: 700; color: #6c757d; background: #f1f3f5; padding: 2px 8px; border-radius: 6px; margin-left: 8px; }
    .contract-dates { font-size: 0.8rem; color: #6c757d; margin-top: 4px; display: flex; align-items: center; gap: 5px; }

    .status-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.3em 0.85em;
        border-radius: 20px;
        font-size: 0.75rem; font-weight: 700;
        white-space: nowrap;
    }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }

    .contract-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem; }
    .contract-note {
        margin-top: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.8rem;
        color: #6c757d;
    }
    .contract-note-locked { color: #b02a37; }
    .contract-note-editable { color: #0f5132; }

    .btn-view {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.45rem 1rem;
        border-radius: 8px; font-size: 0.8rem; font-weight: 600;
        text-decoration: none; transition: all 0.2s ease;
    }
    .btn-view-primary { background: #0d6efd; color: #fff; }
    .btn-view-primary:hover { background: #0b5ed7; color: #fff; transform: translateY(-1px); }
    .btn-view-outline { background: transparent; color: #0d6efd; border: 1.5px solid rgba(13,110,253,0.3); }
    .btn-view-outline:hover { background: rgba(13,110,253,0.06); color: #0d6efd; }

    .refusal-block {
        margin-top: 0.75rem;
        background: #fff5f5;
        border: 1px solid rgba(220,53,69,0.2);
        border-radius: 10px;
        padding: 0.85rem 1rem;
        font-size: 0.825rem;
        color: #842029;
    }

    .empty-state {
        text-align: center; padding: 3.5rem 1rem; color: #adb5bd;
    }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
    .empty-state p { font-size: 0.875rem; margin: 0; }

    /* ── FOOTER ───────────────────────────────────────────────────────── */
    .dashboard-footer {
        display: flex; justify-content: center; gap: 0.75rem;
        flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.07);
    }
    .btn-footer {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.45rem 1rem; border-radius: 8px;
        font-size: 0.8rem; font-weight: 600;
        color: #6c757d; background: transparent;
        border: 1.5px solid rgba(0,0,0,0.12);
        text-decoration: none; transition: all 0.2s ease;
    }
    .btn-footer:hover { background: #f8f9fa; color: #495057; border-color: rgba(0,0,0,0.2); }
</style>

<main class="container py-5">

    {# ── HERO ── #}
    <div class="student-hero">
        <div class="d-flex align-items-center gap-3">
            <div class="student-hero-avatar">
                {{ student.firstname|first }}{{ student.lastname|first }}
            </div>
            <div>
                <h1>{{ student.firstname }} {{ student.lastname }}</h1>
                <p><i class="ph ph-graduation-cap me-1"></i>{{ student.level.levelName ?? 'Étudiant' }}</p>
            </div>
        </div>
        <a href="{{ path('app_student_contract_init') }}" class="hero-cta">
            <i class="ph-bold ph-plus"></i> Nouvelle convention
        </a>
    </div>

    {# ── STAT CARDS ── #}
    <div class="stat-grid">

        {# Statut convention active #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(13,110,253,0.1);">
                <i class="ph ph-file-text" style="color:#0d6efd;"></i>
            </div>
            <div>
                <div class="stat-label">Statut actuel</div>
                <div style="font-size:1rem;font-weight:700;color:#1a1a2e;margin-top:4px;">
                    {% if contract_status == 'Aucune convention' %}
                        <span style="color:#adb5bd;">Aucune</span>
                    {% else %}
                        {{ contract_status }}
                    {% endif %}
                </div>
            </div>
        </div>

        {# Jours restants #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(13,202,240,0.1);">
                <i class="ph ph-calendar" style="color:#0dcaf0;"></i>
            </div>
            <div>
                <div class="stat-value">{{ remaining_days }}</div>
                <div class="stat-label">Jours restants</div>
            </div>
        </div>

        {# Historique #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(25,135,84,0.1);">
                <i class="ph ph-check-circle" style="color:#198754;"></i>
            </div>
            <div>
                <div class="stat-value">{{ past_contracts_count }}</div>
                <div class="stat-label">Convention{{ past_contracts_count > 1 ? 's' : '' }} passée{{ past_contracts_count > 1 ? 's' : '' }}</div>
            </div>
        </div>

    </div>

    {# ── MACRO contenu d'une convention ── #}
    {% macro contract_row(contract) %}
        <div class="contract-item">
            <div class="contract-top">
                <div>
                    <div>
                        <span class="contract-company">
                            <i class="ph ph-buildings me-1 text-muted"></i>
                            {{ contract.organisation is defined and contract.organisation.name is defined ? contract.organisation.name : 'Entreprise inconnue' }}
                        </span>
                        <span class="contract-id">#{{ contract.id }}</span>
                    </div>
                    <div class="contract-dates">
                        <i class="ph ph-calendar-blank"></i>
                        {{ contract.stageStartDate ? contract.stageStartDate|date('d/m/Y') : 'N/A' }}
                        <i class="ph ph-arrow-right" style="font-size:0.65rem;"></i>
                        {{ contract.stageEndDate ? contract.stageEndDate|date('d/m/Y') : 'N/A' }}
                    </div>
                </div>
            </div>

            <div class="contract-actions">
                {% if contract.status == 'collection_sent' %}
                    <a href="{{ path('app_contract_edit', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                        <i class="ph ph-pencil-simple"></i> Modifier la collecte
                    </a>
                {% elseif contract.status == 'filled_by_company' %}
                    <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-primary">
                        <i class="ph-bold ph-clipboard-text"></i> Vérifier et valider
                    </a>
                {% elseif contract.status == 'refused' %}
                    <a href="{{ path('app_contract_edit', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                        <i class="ph ph-pencil-simple"></i> Modifier la collecte
                    </a>
                {% else %}
                    <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                        <i class="ph ph-eye"></i> Voir la convention
                    </a>
                {% endif %}
                {% if contract.pdfSigned or contract.pdfUnsigned %}
                    <a href="{{ path('app_student_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-view btn-view-primary">
                        <i class="ph ph-file-pdf"></i> Ouvrir le PDF
                    </a>
                {% endif %}
            </div>

            {% if contract.status == 'refused' %}
                <div class="refusal-block">
                    <strong><i class="ph ph-x-circle me-1"></i>Convention refusée.</strong>
                    {% if contract.professorRejectionReason %}
                        <div class="mt-1">{{ contract.professorRejectionReason|nl2br }}</div>
                    {% elseif contract.ddfRejectionReason %}
                        <div class="mt-1">{{ contract.ddfRejectionReason|nl2br }}</div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    {% endmacro %}

    {# ── FILTRAGE PAR STATUT ── #}
    {% set c_waiting_tutor  = contracts|filter(c => c.status == 'collection_sent') %}
    {% set c_to_validate    = contracts|filter(c => c.status == 'filled_by_company') %}
    {% set c_waiting_prof   = contracts|filter(c => c.status == 'validated_by_student') %}
    {% set c_waiting_ddf    = contracts|filter(c => c.status in ['validated_by_prof', 'validated_by_ddf']) %}
    {% set c_signing        = contracts|filter(c => c.status == 'signature_requested') %}
    {% set c_signed         = contracts|filter(c => c.status == 'signed') %}
    {% set c_refused        = contracts|filter(c => c.status == 'refused') %}

    {# ── HELPER MACRO : ligne convention ── #}
    {% macro row(contract, note, noteIcon) %}
        <div class="contract-item">
            <div class="contract-top">
                <div>
                    <span class="contract-company">
                        <i class="ph ph-buildings me-1 text-muted"></i>
                        {{ contract.organisation is defined and contract.organisation.name is defined ? contract.organisation.name : 'Entreprise inconnue' }}
                    </span>
                    <span class="contract-id">#{{ contract.id }}</span>
                    <div class="contract-dates">
                        <i class="ph ph-calendar-blank"></i>
                        {{ contract.stageStartDate ? contract.stageStartDate|date('d/m/Y') : 'N/A' }}
                        <i class="ph ph-arrow-right" style="font-size:0.65rem;"></i>
                        {{ contract.stageEndDate ? contract.stageEndDate|date('d/m/Y') : 'N/A' }}
                    </div>
                </div>
            </div>
            <div class="contract-actions">
                {% if contract.status == 'collection_sent' or contract.status == 'refused' %}
                    <a href="{{ path('app_contract_edit', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                        <i class="ph ph-pencil-simple"></i> Modifier
                    </a>
                {% elseif contract.status == 'filled_by_company' %}
                    <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-primary">
                        <i class="ph-bold ph-clipboard-text"></i> Vérifier et valider
                    </a>
                {% else %}
                    <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                        <i class="ph ph-eye"></i> Voir
                    </a>
                {% endif %}
                {% if contract.status == 'signed' and (contract.pdfSigned or contract.pdfUnsigned) %}
                    <a href="{{ path('app_student_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-view btn-view-primary">
                        <i class="ph ph-file-pdf"></i> Télécharger le PDF
                    </a>
                {% endif %}
            </div>
            {% if note %}
                <div class="contract-note"><i class="ph ph-{{ noteIcon }}"></i> {{ note }}</div>
            {% endif %}
            {% if contract.status == 'refused' %}
                <div class="refusal-block">
                    <strong><i class="ph ph-x-circle me-1"></i>Convention refusée.</strong>
                    {% if contract.professorRejectionReason %}<div class="mt-1">{{ contract.professorRejectionReason|nl2br }}</div>
                    {% elseif contract.ddfRejectionReason %}<div class="mt-1">{{ contract.ddfRejectionReason|nl2br }}</div>{% endif %}
                </div>
            {% endif %}
        </div>
    {% endmacro %}

    {# ── MACRO section complète ── #}
    {% macro section(dot_color, title, badge_bg, badge_color, contracts, empty_icon, empty_msg, always_show, note, noteIcon) %}
        {% if always_show or contracts is not empty %}
        <div class="contracts-section">
            <div class="contracts-header">
                <span class="section-dot" style="background:{{ dot_color }};"></span>
                <h2>{{ title }}</h2>
                <span class="badge-count badge" style="background:{{ badge_bg }};color:{{ badge_color }};">{{ contracts|length }}</span>
            </div>
            {% if contracts is empty %}
                <div class="empty-state" style="padding:1.75rem 1rem;">
                    <i class="ph ph-{{ empty_icon }}" style="font-size:1.8rem;color:#adb5bd;display:block;margin-bottom:0.4rem;"></i>
                    <p style="font-size:0.82rem;">{{ empty_msg }}</p>
                </div>
            {% else %}
                {% for contract in contracts %}{{ _self.row(contract, note, noteIcon) }}{% endfor %}
            {% endif %}
        </div>
        {% endif %}
    {% endmacro %}

    {# ─────────────────────────────────────────────────── #}
    {# BLOC 1 — En attente de la saisie du tuteur          #}
    {{ _self.section(
        '#0d6efd', 'En attente de la saisie du tuteur',
        'rgba(13,110,253,0.1)', '#0d6efd',
        c_waiting_tutor,
        'envelope-simple-open', 'Aucune convention en attente du tuteur.',
        false,
        'Un email a été envoyé à votre tuteur. Il doit remplir les informations de l\'entreprise.',
        'envelope-open'
    ) }}

    {# BLOC 2 — À valider par vous                         #}
    {{ _self.section(
        '#ffc107', 'À valider par vous',
        'rgba(255,193,7,0.15)', '#856404',
        c_to_validate,
        'clipboard-text', 'Aucune convention à valider.',
        false,
        'Le tuteur a rempli les informations. Vérifiez et validez avant envoi au professeur.',
        'info'
    ) }}

    {# BLOC 3 — En attente de la validation du professeur  #}
    {{ _self.section(
        '#6ea8fe', 'En attente de la validation du professeur',
        'rgba(110,168,254,0.15)', '#084298',
        c_waiting_prof,
        'chalkboard-teacher', 'Aucune convention en attente du professeur.',
        false,
        'Vous avez validé. Votre professeur référent doit maintenant valider la convention.',
        'hourglass-medium'
    ) }}

    {# BLOC 4 — En attente de la validation de la DDF      #}
    {{ _self.section(
        '#0dcaf0', 'En attente de la validation de la DDF',
        'rgba(13,202,240,0.12)', '#055160',
        c_waiting_ddf,
        'buildings', 'Aucune convention en attente de la DDF.',
        false,
        'Le professeur a validé. La direction des formations finalise la vérification administrative.',
        'hourglass-medium'
    ) }}

    {# BLOC 5 — En attente des signatures                  #}
    {{ _self.section(
        '#6f42c1', 'En attente des signatures',
        'rgba(111,66,193,0.1)', '#6f42c1',
        c_signing,
        'pen-nib', 'Aucune convention en cours de signature.',
        false,
        'La convention a été envoyée aux signataires (étudiant, tuteur, professeur, proviseur).',
        'pen-nib'
    ) }}

    {# BLOC 6 — Tout le monde a signé — toujours visible   #}
    <div class="contracts-section">
        <div class="contracts-header">
            <span class="section-dot" style="background:#198754;"></span>
            <h2>Convention finalisée — tout le monde a signé</h2>
            <span class="badge-count badge" style="background:rgba(25,135,84,0.1);color:#198754;">{{ c_signed|length }}</span>
        </div>
        {% if c_signed is empty %}
            <div class="empty-state" style="padding:1.75rem 1rem;">
                <i class="ph ph-seal-check" style="font-size:1.8rem;color:#adb5bd;display:block;margin-bottom:0.4rem;"></i>
                <p style="font-size:0.82rem;">Pas encore de convention entièrement signée.</p>
            </div>
        {% else %}
            {% for contract in c_signed %}
                <div class="contract-item">
                    <div class="contract-top">
                        <div>
                            <span class="contract-company">
                                <i class="ph ph-buildings me-1 text-muted"></i>
                                {{ contract.organisation is defined and contract.organisation.name is defined ? contract.organisation.name : 'Entreprise inconnue' }}
                            </span>
                            <span class="contract-id">#{{ contract.id }}</span>
                            <div class="contract-dates">
                                <i class="ph ph-calendar-blank"></i>
                                {{ contract.stageStartDate ? contract.stageStartDate|date('d/m/Y') : 'N/A' }}
                                <i class="ph ph-arrow-right" style="font-size:0.65rem;"></i>
                                {{ contract.stageEndDate ? contract.stageEndDate|date('d/m/Y') : 'N/A' }}
                            </div>
                        </div>
                        <span class="status-chip" style="background:#d1e7dd;color:#0a3622;">
                            <span class="status-dot" style="background:#198754;"></span>Signée
                        </span>
                    </div>
                    <div class="contract-actions">
                        <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                            <i class="ph ph-eye"></i> Voir
                        </a>
                        {% if contract.pdfSigned or contract.pdfUnsigned %}
                            <a href="{{ path('app_student_contract_pdf', {'id': contract.id}) }}" target="_blank" class="btn-view btn-view-primary">
                                <i class="ph ph-file-pdf"></i> Télécharger le PDF
                            </a>
                        {% endif %}
                    </div>
                    <div class="contract-note" style="color:#198754;">
                        <i class="ph ph-seal-check"></i> Convention entièrement signée et finalisée.
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    {# BLOC REFUSÉES — seulement si nécessaire             #}
    {{ _self.section(
        '#dc3545', 'Conventions refusées',
        'rgba(220,53,69,0.1)', '#dc3545',
        c_refused,
        'x-circle', '',
        false, '', ''
    ) }}

    {# ── FOOTER ── #}
    <div class="dashboard-footer">
        <a href="{{ path('app_forgot_password_request') }}" class="btn-footer">
            <i class="ph ph-lock"></i> Réinitialiser mon mot de passe
        </a>
        <a href="{{ path('app_home') }}" class="btn-footer">
            <i class="ph ph-house"></i> Retour à l'accueil
        </a>
    </div>

</main>
{% endblock %}
