{% extends 'base.html.twig' %}

{% block title %}Tutor{% endblock %}

{% block back_button %}
    <div class="container pt-3">
        <button onclick="history.back()" class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;padding:0;">
            <i class="ph ph-arrow-left" style="font-size:1.1rem;"></i>
        </button>
    </div>
{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card shadow-sm rounded-3 border-0">
                    <div class="card-header bg-white border-bottom p-3">
                        <h1 class="h4 mb-0 text-primary">Fiche Tuteur</h1>
                    </div>
                    <div class="card-body p-3 p-md-4">
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle mb-0">
                                <tbody>
                                    <tr>
                                        <th class="bg-light w-25">Id</th>
                                        <td>{{ tutor.id }}</td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Email</th>
                                        <td>{{ tutor.email }}</td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Rôles</th>
                                        <td>{{ tutor.roles ? tutor.roles|json_encode : '' }}</td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Nom</th>
                                        <td>{{ tutor.name }}</td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Tél. Mobile</th>
                                        <td>{{ tutor.telMobile }}</td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Tél. Autre</th>
                                        <td>{{ tutor.telOther }}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex flex-wrap gap-2 p-3">
                        <a href="{{ path('app_tutor_index') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-list me-1"></i> Retour à la liste
                        </a>
                        <a href="{{ path('app_tutor_edit', {'id': tutor.id}) }}" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit me-1"></i> Modifier
                        </a>
                        {{ include('tutor/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
