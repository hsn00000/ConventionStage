<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Conventio{% endblock %}</title>
    <!--[if mso]>
    <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
    <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#eef2ff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#eef2ff;padding:32px 16px;">
<tr><td align="center">

    {# ── Wrapper 600px ── #}
    <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        {# ── En-tête logo ── #}
        <tr>
            <td align="center" style="padding-bottom:24px;">
                <table cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:12px;padding:10px 20px;">
                            <span style="color:#ffffff;font-size:20px;font-weight:700;letter-spacing:0.04em;">✦ Conventio</span>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        {# ── Carte principale ── #}
        <tr>
            <td style="background:#ffffff;border-radius:20px;box-shadow:0 4px 24px rgba(13,110,253,0.10);overflow:hidden;">

                {# Bande de couleur en haut #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:linear-gradient(120deg,#0a58ca 0%,#0d6efd 55%,#6ea8fe 100%);height:6px;font-size:0;line-height:0;">&nbsp;</td>
                    </tr>
                </table>

                {# Icône / titre de section #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td align="center" style="padding:36px 40px 8px;">
                            <div style="display:inline-block;background:rgba(13,110,253,0.08);border:1px solid rgba(13,110,253,0.2);border-radius:50px;padding:6px 18px;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#0d6efd;">
                                {% block badge %}Lycée Gabriel Fauré{% endblock %}
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="padding:16px 40px 4px;">
                            <h1 style="margin:0;font-size:24px;font-weight:700;color:#1a1a2e;line-height:1.3;">
                                {% block heading %}{% endblock %}
                            </h1>
                        </td>
                    </tr>
                </table>

                {# Corps du message #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="padding:24px 40px 0;">
                            {% block body %}{% endblock %}
                        </td>
                    </tr>
                </table>

                {# Bouton CTA (optionnel) #}
                {% block cta %}{% endblock %}

                {# Séparateur & pied de carte #}
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="padding:32px 40px 0;">
                            <hr style="border:none;border-top:1px solid #e9ecef;margin:0;">
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 40px 36px;">
                            <p style="margin:0;font-size:13px;color:#6c757d;line-height:1.6;">
                                Cordialement,<br>
                                <strong style="color:#495057;">L'équipe administrative du Lycée Gabriel Fauré</strong>
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>

        {# ── Pied de page ── #}
        <tr>
            <td align="center" style="padding-top:24px;">
                <p style="margin:0;font-size:11px;color:#9ca3af;line-height:1.7;">
                    Cet email a été envoyé automatiquement par la plateforme <strong>Conventio</strong>.<br>
                    Merci de ne pas répondre directement à ce message.
                </p>
            </td>
        </tr>

    </table>

</td></tr>
</table>

</body>
</html>
