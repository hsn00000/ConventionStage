{# templates/student/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord{% endblock %}

{% block content %}
<style>
    /* ── HERO ─────────────────────────────────────────────────────────── */
    .student-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #6ea8fe 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        color: #fff;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .student-hero-avatar {
        width: 56px; height: 56px;
        background: rgba(255,255,255,0.2);
        border: 2px solid rgba(255,255,255,0.35);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; font-weight: 800; color: #fff;
        flex-shrink: 0;
    }
    .student-hero h1 { font-weight: 800; font-size: 1.5rem; letter-spacing: -0.02em; margin: 0; }
    .student-hero p  { opacity: 0.75; margin: 0.25rem 0 0; font-size: 0.875rem; }
    .hero-cta {
        background: #fff;
        color: #0d6efd;
        border: none;
        border-radius: 50px;
        padding: 0.6rem 1.4rem;
        font-weight: 700;
        font-size: 0.875rem;
        display: inline-flex; align-items: center; gap: 6px;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        white-space: nowrap;
    }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); color: #0b5ed7; }

    /* ── STAT CARDS ───────────────────────────────────────────────────── */
    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
    @media (max-width: 767px) { .stat-grid { grid-template-columns: 1fr; } }

    .stat-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        padding: 1.35rem 1.5rem;
        display: flex; align-items: center; gap: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.09); }
    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; flex-shrink: 0;
    }
    .stat-value { font-size: 1.75rem; font-weight: 800; line-height: 1; color: #1a1a2e; }
    .stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #6c757d; margin-top: 3px; }

    /* ── CONVENTION LIST ──────────────────────────────────────────────── */
    .contracts-section {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .contracts-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .contracts-header h2 { font-size: 0.95rem; font-weight: 700; margin: 0; color: #1a1a2e; }

    .contract-item {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        transition: background 0.15s ease;
    }
    .contract-item:last-child { border-bottom: none; }
    .contract-item:hover { background: #f8fbff; }

    .contract-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .contract-company { font-weight: 700; font-size: 1rem; color: #1a1a2e; }
    .contract-id { font-size: 0.72rem; font-weight: 700; color: #6c757d; background: #f1f3f5; padding: 2px 8px; border-radius: 6px; margin-left: 8px; }
    .contract-dates { font-size: 0.8rem; color: #6c757d; margin-top: 4px; display: flex; align-items: center; gap: 5px; }

    .status-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.3em 0.85em;
        border-radius: 20px;
        font-size: 0.75rem; font-weight: 700;
        white-space: nowrap;
    }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }

    .contract-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem; }
    .contract-note {
        margin-top: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.8rem;
        color: #6c757d;
    }
    .contract-note-locked { color: #b02a37; }
    .contract-note-editable { color: #0f5132; }

    .btn-view {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.45rem 1rem;
        border-radius: 8px; font-size: 0.8rem; font-weight: 600;
        text-decoration: none; transition: all 0.2s ease;
    }
    .btn-view-primary { background: #0d6efd; color: #fff; }
    .btn-view-primary:hover { background: #0b5ed7; color: #fff; transform: translateY(-1px); }
    .btn-view-outline { background: transparent; color: #0d6efd; border: 1.5px solid rgba(13,110,253,0.3); }
    .btn-view-outline:hover { background: rgba(13,110,253,0.06); color: #0d6efd; }

    .refusal-block {
        margin-top: 0.75rem;
        background: #fff5f5;
        border: 1px solid rgba(220,53,69,0.2);
        border-radius: 10px;
        padding: 0.85rem 1rem;
        font-size: 0.825rem;
        color: #842029;
    }

    .empty-state {
        text-align: center; padding: 3.5rem 1rem; color: #adb5bd;
    }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
    .empty-state p { font-size: 0.875rem; margin: 0; }

    /* ── FOOTER ───────────────────────────────────────────────────────── */
    .dashboard-footer {
        display: flex; justify-content: center; gap: 0.75rem;
        flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.07);
    }
    .btn-footer {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 0.45rem 1rem; border-radius: 8px;
        font-size: 0.8rem; font-weight: 600;
        color: #6c757d; background: transparent;
        border: 1.5px solid rgba(0,0,0,0.12);
        text-decoration: none; transition: all 0.2s ease;
    }
    .btn-footer:hover { background: #f8f9fa; color: #495057; border-color: rgba(0,0,0,0.2); }
</style>

<main class="container py-5">

    {# ── HERO ── #}
    <div class="student-hero">
        <div class="d-flex align-items-center gap-3">
            <div class="student-hero-avatar">
                {{ student.firstname|first }}{{ student.lastname|first }}
            </div>
            <div>
                <h1>{{ student.firstname }} {{ student.lastname }}</h1>
                <p><i class="ph ph-graduation-cap me-1"></i>{{ student.level.levelName ?? 'Étudiant' }}</p>
            </div>
        </div>
        <a href="{{ path('app_student_contract_init') }}" class="hero-cta">
            <i class="ph-bold ph-plus"></i> Nouvelle convention
        </a>
    </div>

    {# ── STAT CARDS ── #}
    <div class="stat-grid">

        {# Statut convention active #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(13,110,253,0.1);">
                <i class="ph ph-file-text" style="color:#0d6efd;"></i>
            </div>
            <div>
                <div class="stat-label">Statut actuel</div>
                <div style="font-size:1rem;font-weight:700;color:#1a1a2e;margin-top:4px;">
                    {% if contract_status == 'Aucune convention' %}
                        <span style="color:#adb5bd;">Aucune</span>
                    {% else %}
                        {{ contract_status }}
                    {% endif %}
                </div>
            </div>
        </div>

        {# Jours restants #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(13,202,240,0.1);">
                <i class="ph ph-calendar" style="color:#0dcaf0;"></i>
            </div>
            <div>
                <div class="stat-value">{{ remaining_days }}</div>
                <div class="stat-label">Jours restants</div>
            </div>
        </div>

        {# Historique #}
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(25,135,84,0.1);">
                <i class="ph ph-check-circle" style="color:#198754;"></i>
            </div>
            <div>
                <div class="stat-value">{{ past_contracts_count }}</div>
                <div class="stat-label">Convention{{ past_contracts_count > 1 ? 's' : '' }} passée{{ past_contracts_count > 1 ? 's' : '' }}</div>
            </div>
        </div>

    </div>

    {# ── LISTE DES CONVENTIONS ── #}
    <div class="contracts-section">
        <div class="contracts-header">
            <h2><i class="ph ph-folder-open me-2" style="color:#0d6efd;"></i>Mes conventions</h2>
            <span style="font-size:0.78rem;color:#6c757d;font-weight:600;">{{ contracts|length }} au total</span>
        </div>

        {% if contracts is empty %}
            <div class="empty-state">
                <i class="ph ph-file-dashed"></i>
                <p>Aucune convention trouvée.<br>Créez votre première convention de stage.</p>
            </div>
        {% else %}
            {% for contract in contracts %}
                <div class="contract-item">
                    <div class="contract-top">
                        <div>
                            <div>
                                <span class="contract-company">
                                    <i class="ph ph-buildings me-1 text-muted"></i>
                                    {{ contract.organisation is defined and contract.organisation.name is defined ? contract.organisation.name : 'Entreprise inconnue' }}
                                </span>
                                <span class="contract-id">#{{ contract.id }}</span>
                            </div>
                            <div class="contract-dates">
                                <i class="ph ph-calendar-blank"></i>
                                {{ contract.startDate is defined and contract.startDate is not null ? contract.startDate|date('d/m/Y') : 'N/A' }}
                                <i class="ph ph-arrow-right" style="font-size:0.65rem;"></i>
                                {{ contract.endDate is defined and contract.endDate is not null ? contract.endDate|date('d/m/Y') : 'N/A' }}
                            </div>
                        </div>

                        {# Badge statut #}
                        {% if contract.status == 'Brouillon' %}
                            <span class="status-chip" style="background:#f1f3f5;color:#6c757d;">
                                <span class="status-dot" style="background:#adb5bd;"></span>Brouillon
                            </span>
                        {% elseif contract.status == 'filled_by_company' %}
                            <span class="status-chip" style="background:#fff3cd;color:#856404;">
                                <span class="status-dot" style="background:#ffc107;"></span>{{ contract.statusLabel }}
                            </span>
                        {% elseif contract.status == 'validated_by_student' %}
                            <span class="status-chip" style="background:#e7f1ff;color:#084298;">
                                <span class="status-dot" style="background:#0d6efd;"></span>{{ contract.statusLabel }}
                            </span>
                        {% elseif contract.status == 'validated_by_prof' %}
                            <span class="status-chip" style="background:#cff4fc;color:#055160;">
                                <span class="status-dot" style="background:#0dcaf0;"></span>{{ contract.statusLabel }}
                            </span>
                        {% elseif contract.status == 'signature_requested' %}
                            <span class="status-chip" style="background:#e2e3e5;color:#41464b;">
                                <span class="status-dot" style="background:#6c757d;"></span>{{ contract.statusLabel }}
                            </span>
                        {% elseif contract.status == 'signed' %}
                            <span class="status-chip" style="background:#d1e7dd;color:#0a3622;">
                                <span class="status-dot" style="background:#198754;"></span>{{ contract.statusLabel }}
                            </span>
                        {% elseif contract.status == 'refused' %}
                            <span class="status-chip" style="background:#f8d7da;color:#58151c;">
                                <span class="status-dot" style="background:#dc3545;"></span>{{ contract.statusLabel }}
                            </span>
                        {% else %}
                            <span class="status-chip" style="background:#f1f3f5;color:#6c757d;">
                                <span class="status-dot" style="background:#adb5bd;"></span>{{ contract.statusLabel }}
                            </span>
                        {% endif %}
                    </div>

                    <div class="contract-actions">
                        {% if contract.status == 'collection_sent' or contract.status == 'refused' %}
                            <a href="{{ path('app_contract_edit', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                                <i class="ph ph-pencil-simple"></i> Modifier la collecte
                            </a>
                        {% elseif contract.status == 'filled_by_company' %}
                            <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-primary">
                                <i class="ph-bold ph-clipboard-text"></i> Vérifier et valider
                            </a>
                        {% else %}
                            <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn-view btn-view-outline">
                                <i class="ph ph-eye"></i> Voir la convention
                            </a>
                        {% endif %}
                    </div>

                    {% if contract.status == 'collection_sent' or contract.status == 'refused' %}
                        <div class="contract-note contract-note-editable">
                            <i class="ph ph-info"></i>
                            Cette collecte peut encore être modifiée par l'étudiant.
                        </div>
                    {% elseif contract.status == 'validated_by_student' %}
                        <div class="contract-note">
                            <i class="ph ph-hourglass-medium"></i>
                            Vous avez déjà validé cette convention. Elle est en attente de validation par le professeur.
                        </div>
                    {% elseif contract.status == 'validated_by_prof' %}
                        <div class="contract-note">
                            <i class="ph ph-hourglass-medium"></i>
                            La convention est en attente de validation par la DDF.
                        </div>
                    {% elseif contract.status == 'validated_by_ddf' %}
                        <div class="contract-note">
                            <i class="ph ph-file-arrow-up"></i>
                            La convention a été validée par la DDF. La génération et l'envoi en signature suivent ce statut.
                        </div>
                    {% elseif contract.status == 'signature_requested' %}
                        <div class="contract-note">
                            <i class="ph ph-pen-nib"></i>
                            La convention est partie en signature. L'étudiant ne peut plus la modifier.
                        </div>
                    {% elseif contract.status == 'signed' %}
                        <div class="contract-note">
                            <i class="ph ph-check-circle"></i>
                            La convention est signée et finalisée.
                        </div>
                    {% else %}
                        <div class="contract-note contract-note-locked">
                            <i class="ph ph-lock"></i>
                            Une fois validée ou transmise, cette collecte n'est plus modifiable par l'étudiant.
                        </div>
                    {% endif %}

                    {% if contract.status == 'refused' %}
                        <div class="refusal-block">
                            <strong><i class="ph ph-x-circle me-1"></i>Convention refusée par le professeur référent.</strong>
                            {% if contract.professorRejectionReason %}
                                <div class="mt-1">{{ contract.professorRejectionReason|nl2br }}</div>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        {% endif %}
    </div>

    {# ── FOOTER ── #}
    <div class="dashboard-footer">
        <a href="{{ path('app_forgot_password_request') }}" class="btn-footer">
            <i class="ph ph-lock"></i> Réinitialiser mon mot de passe
        </a>
        <a href="{{ path('app_home') }}" class="btn-footer">
            <i class="ph ph-house"></i> Retour à l'accueil
        </a>
    </div>

</main>
{% endblock %}
