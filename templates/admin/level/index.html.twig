{# templates/admin/level/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Administration des Classes{% endblock %}

{% block content %}
<style>
    .admin-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 16px;
        padding: 2rem 2.5rem;
        color: #fff;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        position: relative;
        overflow: hidden;
    }
    .admin-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.12) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
        border-radius: 16px;
    }
    .admin-hero > * { position: relative; z-index: 1; }
    .admin-hero h1 { font-weight: 800; letter-spacing: -0.03em; font-size: 1.8rem; margin-bottom: 0.25rem; }
    .admin-hero p  { opacity: 0.6; margin: 0; font-size: 0.9rem; }

    .btn-add {
        background: #fff;
        color: #1a1a2e;
        border: none;
        border-radius: 50px;
        padding: 0.55rem 1.4rem;
        font-weight: 700;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none;
        box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    }
    .btn-add:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.35); color: #1a1a2e; }

    .level-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    .level-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.07);
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .level-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.10); }

    .level-card-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #2d2d5e 100%);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .level-code-badge {
        background: rgba(255,255,255,0.15);
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        padding: 0.35em 0.9em;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.2);
    }
    .level-card-header .students-count {
        color: rgba(255,255,255,0.7);
        font-size: 0.78rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .level-card-body { padding: 1.25rem 1.5rem; }
    .level-name { font-size: 1rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1rem; }

    .prof-block {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: #f8f9fa;
        border-radius: 10px;
        margin-bottom: 1rem;
    }
    .prof-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a1a2e, #3d3d7e);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.8rem;
        flex-shrink: 0;
    }
    .prof-name  { font-size: 0.875rem; font-weight: 600; color: #212529; line-height: 1.2; }
    .prof-email { font-size: 0.72rem; color: #6c757d; }

    .no-prof {
        display: flex; align-items: center; gap: 0.5rem;
        padding: 0.65rem 0.75rem;
        background: #fff8e1;
        border-radius: 10px;
        margin-bottom: 1rem;
        font-size: 0.8rem;
        color: #856404;
        border: 1px solid rgba(133,100,4,0.15);
    }

    .level-card-footer {
        display: flex;
        gap: 0.5rem;
        padding: 0 1.5rem 1.25rem;
    }

    .btn-edit {
        flex: 1;
        display: inline-flex; align-items: center; justify-content: center; gap: 5px;
        padding: 0.45rem 0.75rem;
        border-radius: 8px;
        font-size: 0.8rem; font-weight: 600;
        background: transparent;
        color: #1a1a2e;
        border: 1.5px solid rgba(0,0,0,0.15);
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .btn-edit:hover { background: #f8f9fa; color: #1a1a2e; border-color: rgba(0,0,0,0.3); }

    .btn-delete {
        display: inline-flex; align-items: center; justify-content: center; gap: 5px;
        padding: 0.45rem 0.75rem;
        border-radius: 8px;
        font-size: 0.8rem; font-weight: 600;
        background: transparent;
        color: #dc3545;
        border: 1.5px solid rgba(220,53,69,0.25);
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-delete:hover { background: rgba(220,53,69,0.07); border-color: #dc3545; }

    .empty-state {
        text-align: center;
        padding: 4rem 1rem;
        color: #adb5bd;
    }
    .empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; }
    .empty-state h5 { font-weight: 700; color: #6c757d; margin-bottom: 0.5rem; }
    .empty-state p  { font-size: 0.875rem; }
</style>

<main class="container py-5">

    {# HERO #}
    <div class="admin-hero">
        <div>
            <h1><i class="ph-bold ph-chalkboard me-2"></i>Paramétrage des Classes</h1>
            <p>Gérez la structure pédagogique, les niveaux et les professeurs référents.</p>
        </div>
        <a href="{{ path('app_admin_level_new') }}" class="btn-add">
            <i class="ph-bold ph-plus"></i> Ajouter une classe
        </a>
    </div>

    {# FLASH MESSAGES #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="ph-bold ph-check-circle fs-5"></i>
            <div>{{ message }}</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {# GRILLE DE CLASSES #}
    {% if levels is empty %}
        <div class="empty-state">
            <i class="ph ph-chalkboard-teacher"></i>
            <h5>Aucune classe configurée</h5>
            <p class="mb-4">Ajoutez des classes pour permettre aux étudiants de s'inscrire.</p>
            <a href="{{ path('app_admin_level_new') }}" class="btn-add" style="display:inline-flex;">
                <i class="ph-bold ph-plus"></i> Ajouter une classe
            </a>
        </div>
    {% else %}
        <div class="level-grid">
            {% for level in levels %}
                <div class="level-card">

                    <div class="level-card-header">
                        <span class="level-code-badge">{{ level.levelCode }}</span>
                        <span class="students-count">
                            <i class="ph ph-users"></i>
                            {{ level.students|length }} étudiant{{ level.students|length > 1 ? 's' : '' }}
                        </span>
                    </div>

                    <div class="level-card-body">
                        <div class="level-name">
                            <i class="ph ph-book-open me-1 text-muted"></i>
                            {{ level.levelName }}
                        </div>

                        {% if level.mainProfessor %}
                            <div class="prof-block">
                                <div class="prof-avatar">
                                    {{ level.mainProfessor.firstname|first }}{{ level.mainProfessor.lastname|first }}
                                </div>
                                <div>
                                    <div class="prof-name">{{ level.mainProfessor.firstname }} {{ level.mainProfessor.lastname }}</div>
                                    <div class="prof-email">{{ level.mainProfessor.email }}</div>
                                </div>
                            </div>
                        {% else %}
                            <div class="no-prof">
                                <i class="ph ph-warning"></i>
                                Aucun professeur référent assigné
                            </div>
                        {% endif %}
                    </div>

                    <div class="level-card-footer">
                        <a href="{{ path('app_admin_level_edit', {'id': level.id}) }}" class="btn-edit">
                            <i class="ph ph-pencil"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_admin_level_delete', {'id': level.id}) }}"
                              onsubmit="return confirm('Supprimer la classe {{ level.levelCode }} ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ level.id) }}">
                            <button class="btn-delete" type="submit">
                                <i class="ph ph-trash"></i> Supprimer
                            </button>
                        </form>
                    </div>

                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="mt-4">
        <a href="{{ path('app_home') }}" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1">
            <i class="ph ph-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

</main>
{% endblock %}
