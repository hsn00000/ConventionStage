{% extends 'emails/layout.html.twig' %}

{% block title %}Demande de Convention de Stage – Conventio{% endblock %}
{% block icon %}🏢{% endblock %}
{% block badge %}Demande de Convention{% endblock %}
{% block heading %}Une convention de stage<br>vous attend{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">Bonjour,</p>

    <p style="margin:0 0 24px;font-size:15px;color:#495057;line-height:1.7;">
        L'étudiant(e) <strong style="color:#1a1a2e;">{{ student.firstname }} {{ student.lastname }}</strong>
        du <strong style="color:#1a1a2e;">Lycée Gabriel Fauré</strong> souhaite effectuer un stage au sein de votre entreprise.
    </p>

    {# Bloc étudiant #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f0f4ff;border-radius:12px;padding:18px 20px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="width:40px;vertical-align:top;">
                            <div style="width:36px;height:36px;background:linear-gradient(135deg,#0d6efd,#6ea8fe);border-radius:50%;text-align:center;line-height:36px;font-size:16px;color:#fff;font-weight:800;">
                                {{ student.firstname|first }}
                            </div>
                        </td>
                        <td style="padding-left:12px;vertical-align:middle;">
                            <p style="margin:0 0 2px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6ea8fe;">Étudiant(e) concerné(e)</p>
                            <p style="margin:0;font-size:15px;font-weight:700;color:#1a1a2e;">{{ student.firstname }} {{ student.lastname }}</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 16px;font-size:15px;color:#495057;line-height:1.7;">
        Pour établir la convention de stage officielle, nous avons besoin de collecter quelques informations administratives et logistiques auprès de votre entreprise.
    </p>

    <p style="margin:0 0 8px;font-size:15px;color:#495057;line-height:1.7;">
        Cela ne prend que <strong style="color:#0d6efd;">quelques minutes</strong>. Cliquez sur le bouton ci-dessous pour accéder au formulaire sécurisé :
    </p>
{% endblock %}

{% block cta %}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="padding:28px 40px 16px;">
                <a href="{{ url('app_company_fill', {'token': token}) }}"
                   style="display:inline-block;background:linear-gradient(135deg,#0d6efd,#6ea8fe);color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:15px 36px;border-radius:50px;letter-spacing:0.02em;box-shadow:0 6px 20px rgba(13,110,253,0.4);">
                    Remplir le formulaire de stage &rarr;
                </a>
            </td>
        </tr>
        <tr>
            <td style="padding:0 40px 16px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background:#f8f9fa;border-radius:8px;padding:12px 16px;">
                            <p style="margin:0;font-size:12px;color:#6c757d;line-height:1.6;">
                                🔗 Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :<br>
                                <span style="color:#0d6efd;word-break:break-all;font-size:11px;">{{ url('app_company_fill', {'token': token}) }}</span>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
{% endblock %}
